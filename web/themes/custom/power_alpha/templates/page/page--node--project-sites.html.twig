{#
/**
 * @file
 * Power Alpha (FabriTrack) page template — node detail pages.
 *
 * Used for: project_sites, purchase_order, expenses, invoice.
 * Identical structure to page.html.twig, provided as a separate
 * suggestion so Drupal resolves the correct template per bundle.
 *
 * @see template_preprocess_page()
 * @see power_alpha_theme_suggestions_page_alter()
 */
#}
{% set page_title_block = active_admin_theme ~ '_page_title' %}
{% set local_actions_block = active_admin_theme ~ '_local_actions' %}

<div
	class="fabritrack-layout">

	{# ── 1. ADMIN TOOLBAR ── #}
	<div class="gin-secondary-toolbar layout-container">
		<div class="gin-breadcrumb-wrapper">
			{% if route_name == 'entity.node.canonical' %}
				<div class="region region-breadcrumb gin-region-breadcrumb">
					<nav class="breadcrumb" role="navigation" aria-labelledby="system-breadcrumb">
						<h2 id="system-breadcrumb" class="visually-hidden">{{ 'Breadcrumb'|t }}</h2>
						<ol class="breadcrumb__list">
							<li class="breadcrumb__item">
								{% if entity_edit_url and entity_title %}
									<a class="breadcrumb__link gin-back-to-admin" href="{{ entity_edit_url }}">{{ 'Edit %title'|t({ '%title': entity_title }) }}</a>
								{% else %}
									<a class="breadcrumb__link gin-back-to-admin" href="{{ path('system.admin_content') }}">{{ 'Back to Administration'|t }}</a>
								{% endif %}
							</li>
						</ol>
					</nav>
				</div>
			{% else %}
				{{ page.breadcrumb }}
			{% endif %}
		</div>
		{{ page.gin_secondary_toolbar }}
	</div>

	{% if page.highlighted %}
		<div class="highlighted-wrapper">
			{{ page.highlighted }}
		</div>
	{% endif %}
	{# ── 2. STICKY HEADER ── #}
	<div class="region-sticky-watcher"></div>

	<header class="region region-sticky fabritrack-header {{ gin_form_actions_class }}">
		<div class="layout-container region-sticky__items">
			<div class="region-sticky__items__inner">
				{% if site_logo %}
					<div class="header-logo-wrapper">
						<a href="{{ front_page }}" title="{{ 'Home'|t }}" rel="home">
							<img src="{{ site_logo }}" alt="{{ 'Site Logo'|t }}" class="site-logo-image"/>
						</a>
					</div>
				{% endif %}

				<nav class="fabritrack-main-menu" role="navigation">
					{% if page.main_menu %}
						{{ page.main_menu }}
					{% endif %}
					<div class="menu-footer">
						{% if logged_in %}
							<a href="/user/logout" class="logout-link">
								<svg width="18" height="18" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
									<polyline points="16 17 21 12 16 7"></polyline>
									<line x1="21" y1="12" x2="9" y2="12"></line>
								</svg>
								<span class="logout-text">Logout</span>
							</a>
						{% else %}
							<a href="/user/login" class="logout-link">
								<svg width="18" height="18" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
									<path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"></path>
									<polyline points="10 17 15 12 10 7"></polyline>
									<line x1="15" y1="12" x2="3" y2="12"></line>
								</svg>
								<span class="logout-text">Login</span>
							</a>
						{% endif %}
					</div>
				</nav>

				{# {{ page.header[page_title_block] }} #}
				{% if not active_navigation_top_bar %}
					{{ page.content[local_actions_block] }}
				{% endif %}
				{{ gin_form_actions }}
			</div>
		</div>
	</header>

	<div class="sticky-shadow"></div>

	{# ── 3. BODY (Sidebar + Main) ── #}
	<div
		class="fabritrack-body">

		{# ── MAIN CONTENT ── #}
		<main class="fabritrack-main" role="main">
			<div class="main-content-inner">

				{% if custom_breadcrumbs and custom_breadcrumbs|length > 1 %}
					<nav class="entity-breadcrumb no-print" aria-label="Breadcrumb">
						<ol class="breadcrumb__list" style="display: flex; list-style: none; padding: 0; margin: 0; align-items: center; gap: 8px;">
							{% for bc in custom_breadcrumbs %}
								{% if loop.index0 > 0 %}
									<span class="breadcrumb-sep" aria-hidden="true">
										<svg width="14" height="14" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" focusable="false">
											<polyline points="9 18 15 12 9 6"/>
										</svg>
									</span>
								{% endif %}
								<li class="breadcrumb__item" style="display: inline-flex; align-items: center;">
									{% if bc.current %}
										<span class="breadcrumb-current" aria-current="page">{{ bc.title }}</span>
									{% else %}
										<a href="{{ bc.url }}" class="breadcrumb-link">
											{% if bc.is_home %}
												<svg width="16" height="16" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false" style="vertical-align: middle; margin-right: 4px; margin-top: -2px;">
													<path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
													<polyline points="9 22 9 12 15 12 15 22"/>
												</svg>
											{% endif %}
											{{ bc.title }}
										</a>
									{% endif %}
								</li>
							{% endfor %}
						</ol>
					</nav>
				{% endif %}

				{% if page.pre_content %}
					<div class="pre-content-wrapper">
						{{ page.pre_content }}
					</div>
				{% endif %}

				{% if page.help %}
					<div class="help-wrapper">
						{{ page.help }}
					</div>
				{% endif %}

				<div class="main-drupal-content">
					{{ page.content }}
				</div>

			</div>
		</main>

	</div>
</div>

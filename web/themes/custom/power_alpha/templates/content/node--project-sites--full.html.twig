{#
/**
 * @file
 * Premium project detail page template for project_sites content type.
 *
 * Displays project info card, summary widgets, timeline, tabbed sections
 * with dynamic data from Drupal fields and embedded Views.
 */
#}
<div
	class="project-detail-page">



	{# ── PROJECT HEADER SECTION ── #}
	<div class="project-detail-header">
		<div class="project-detail-header__left">
			<div class="project-detail-header__title-row">
				<h1 class="project-detail-title">{{ label }}</h1>
				{% set status_val = content.field_status.0|render|striptags|trim|lower %}
				<span class="project-status-chip status-chip--{{ status_val }}">
					{{ content.field_status.0 }}
				</span>
			</div>
		</div>
		{% if logged_in %}
			<div class="project-detail-header__actions">
				<a href="{{ path('entity.node.edit_form', {'node': node.id}) }}" class="btn-detail btn-detail--outline">
					<svg width="16" height="16" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
						<path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
					</svg>
					Edit Details
				</a>
			</div>
		{% endif %}
	</div>

	{# ── PROJECT INFO CARD (Premium Meta) ── #}
	<div class="project-info-card">
		<div class="project-info-card__accent"></div>
		<div class="project-info-grid">
			<div class="project-info-item">
				<div class="info-item__icon">
					<svg width="20" height="20" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<rect x="2" y="4" width="20" height="16" rx="2"/>
						<path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
					</svg>
				</div>
				<div class="info-item__content">
					<span class="info-item__label">Project ID</span>
					<span class="info-item__value">#{{ content.field_project_code.0|render|striptags|trim }}</span>
				</div>
			</div>

			<div class="project-info-item">
				<div class="info-item__icon">
					<svg width="20" height="20" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
						<line x1="16" y1="2" x2="16" y2="6"/>
						<line x1="8" y1="2" x2="8" y2="6"/>
						<line x1="3" y1="10" x2="21" y2="10"/>
					</svg>
				</div>
				<div class="info-item__content">
					<span class="info-item__label">Start Date</span>
					<span class="info-item__value">{{ content.field_start_date.0 }}</span>
				</div>
			</div>

			<div class="project-info-item">
				<div class="info-item__icon">
					<svg width="20" height="20" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
						<polyline points="22 4 12 14.01 9 11.01"/>
					</svg>
				</div>
				<div class="info-item__content">
					<span class="info-item__label">Status</span>
					<span class="info-item__value">
						<span class="status-badge-inline status-{{ status_val }}">{{ content.field_status.0 }}</span>
					</span>
				</div>
			</div>

			<div class="project-info-item">
				<div class="info-item__icon">
					<svg width="20" height="20" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
						<line x1="16" y1="2" x2="16" y2="6"/>
						<line x1="8" y1="2" x2="8" y2="6"/>
						<line x1="3" y1="10" x2="21" y2="10"/>
						<path d="m9 16 2 2 4-4"/>
					</svg>
				</div>
				<div class="info-item__content">
					<span class="info-item__label">End Date</span>
					<span class="info-item__value">{{ content.field_end_date.0 }}</span>
				</div>
			</div>
		</div>
	</div>

	{# ── SUMMARY WIDGETS ROW ── #}
	<div
		class="project-summary-row">

		{# Budget Card #}
		{% if budget_allocated %}
			<div class="summary-widget summary-widget--budget">
				<div class="summary-widget__header">
					<h3 class="summary-widget__title">
						<svg width="20" height="20" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<line x1="12" y1="1" x2="12" y2="23"/>
							<path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
						</svg>
						Project Budget
					</h3>
				</div>
				<div class="summary-widget__body">
					<div class="budget-hero">
						<span class="budget-hero__label">Total Budget</span>
						<span class="budget-hero__amount">{{ budget_allocated }}</span>
					</div>
					<div class="budget-progress-section">
						<div class="budget-progress__meta">
							<span>Budget Utilized: <strong>{{ budget_utilized }}</strong> ({{ budget_percent }}%)</span>
							<span>Remaining: <strong class="budget-progress__remaining">{{ budget_remaining }}</strong></span>
						</div>
						<div class="budget-progress__bar">
							<div class="budget-progress__fill {% if budget_percent >= 90 %}budget-progress__fill--critical{% endif %}" style="width: {{ budget_percent }}%"></div>
						</div>
					</div>
				</div>
			</div>
		{% endif %}

		{# Expenses Card #}
		<div class="summary-widget summary-widget--expenses">
			<div class="summary-widget__header">
				<h3 class="summary-widget__title">
					<svg width="20" height="20" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<line x1="18" y1="20" x2="18" y2="10"/>
						<line x1="12" y1="20" x2="12" y2="4"/>
						<line x1="6" y1="20" x2="6" y2="14"/>
					</svg>
					Project Expenses
				</h3>
			</div>
			<div class="summary-widget__body">
				<div class="expenses-hero">
					<span class="expenses-hero__label">Total Expenses</span>
					<span class="expenses-hero__amount">{{ expenses_total }}</span>
				</div>
				<div class="expenses-breakdown-section">
					<div class="expenses-breakdown__bar">
						{% if expenses_total_raw > 0 %}
							{% if expenses_salary_pct > 0 %}
								<div class="expenses-bar-segment segment--salary" style="width: {{ expenses_salary_pct }}%" title="Wages: {{ expenses_salary }} ({{ expenses_salary_pct }}%)"></div>
							{% endif %}
							{% if expenses_inventory_pct > 0 %}
								<div class="expenses-bar-segment segment--inventory" style="width: {{ expenses_inventory_pct }}%" title="Materials: {{ expenses_inventory }} ({{ expenses_inventory_pct }}%)"></div>
							{% endif %}
							{% if expenses_rent_pct > 0 %}
								<div class="expenses-bar-segment segment--rent" style="width: {{ expenses_rent_pct }}%" title="Rent: {{ expenses_rent }} ({{ expenses_rent_pct }}%)"></div>
							{% endif %}
							{% if expenses_other_pct > 0 %}
								<div class="expenses-bar-segment segment--other" style="width: {{ expenses_other_pct }}%" title="Other: {{ expenses_other }} ({{ expenses_other_pct }}%)"></div>
							{% endif %}
						{% else %}
							<div class="expenses-bar-segment segment--empty" style="width: 100%" title="No Expenses Recorded"></div>
						{% endif %}
					</div>
					<ul class="expenses-breakdown__list">
						<li class="breakdown-item item--salary">
							<span class="breakdown-dot"></span>
							<span class="breakdown-label">Wages</span>
							<span class="breakdown-value">{{ expenses_salary }}</span>
						</li>
						<li class="breakdown-item item--inventory">
							<span class="breakdown-dot"></span>
							<span class="breakdown-label">Materials</span>
							<span class="breakdown-value">{{ expenses_inventory }}</span>
						</li>
						<li class="breakdown-item item--rent">
							<span class="breakdown-dot"></span>
							<span class="breakdown-label">Rent</span>
							<span class="breakdown-value">{{ expenses_rent }}</span>
						</li>
					</ul>
				</div>
			</div>
		</div>

		{# Timeline Card #}
		<div class="summary-widget summary-widget--timeline">
			<div class="summary-widget__header">
				<h3 class="summary-widget__title">
					<svg width="20" height="20" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<circle cx="12" cy="12" r="10"/>
						<polyline points="12 6 12 12 16 14"/>
					</svg>
					Timeline
				</h3>
			</div>
			<div class="summary-widget__body">
				<div class="timeline-dates">
					<div class="timeline-date-item">
						<span class="timeline-date-item__label">Start Date</span>
						<span class="timeline-date-item__value">{{ content.field_start_date.0 }}</span>
					</div>
					<div class="timeline-date-item">
						<span class="timeline-date-item__label">Estimated Completion</span>
						<span class="timeline-date-item__value">{{ content.field_end_date.0 }}</span>
					</div>
				</div>
				<div class="timeline-remaining">
					<svg width="18" height="18" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<circle cx="12" cy="12" r="10"/>
						<polyline points="12 6 12 12 16 14"/>
					</svg>
					<span>{{ days_left }}
						Days Remaining</span>
				</div>
			</div>
		</div>
	</div>

	{# ── MAIN TABBED SECTIONS ── #}
	<div class="project-tabs-section">
		<div class="project-tabs-nav">
			<button class="project-tab active" data-tab="purchase_order">
				<svg width="18" height="18" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
					<polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
					<line x1="12" y1="22.08" x2="12" y2="12"/>
				</svg>
				Purchase Orders
			</button>
			<button class="project-tab" data-tab="expenses">
				<svg width="18" height="18" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<line x1="12" y1="1" x2="12" y2="23"/>
					<path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
				</svg>
				Expenses
			</button>
		</div>

		{# Tab Contents #}
		<div
			class="project-tab-panels">

			{# ── PURCHASE ORDER TAB ── #}
			<div class="project-tab-panel active" id="tab-purchase_order">
				<div class="tab-panel__card">
					{{ purchase_order_block }}
					{% if logged_in %}
						<div class="tab-panel__footer">
							<a href="/node/add/purchase_order?project_id={{ node.id }}" class="btn-detail btn-detail--primary">
								<svg width="16" height="16" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
									<line x1="12" y1="5" x2="12" y2="19"/>
									<line x1="5" y1="12" x2="19" y2="12"/>
								</svg>
								Add Purchase Order
							</a>
						</div>
					{% endif %}
				</div>
			</div>

			{# ── EXPENSES TAB ── #}
			<div class="project-tab-panel" id="tab-expenses">
				<div class="tab-panel__card">
					{{ expenses_block }}
					{% if logged_in %}
						<div class="tab-panel__footer">
							<a href="/node/add/expenses?project_id={{ node.id }}" class="btn-detail btn-detail--primary">
								<svg width="16" height="16" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
									<line x1="12" y1="5" x2="12" y2="19"/>
									<line x1="5" y1="12" x2="19" y2="12"/>
								</svg>
								Add Expense
							</a>
						</div>
					{% endif %}
				</div>
			</div>

		</div>
	</div>

</div>

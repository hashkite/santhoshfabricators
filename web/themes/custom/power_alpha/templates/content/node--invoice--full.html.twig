{#
/**
 * @file
 * Premium tax invoice detail template matching standard Indian Tax Invoice format.
 */
#}
<div class="entity-detail-page entity-detail--invoice printable-invoice">



	{# ── ACTIONS ── #}
	<div class="entity-detail-header no-print">
		<div class="entity-detail-header__left">
			<h1 class="entity-detail-title">{{ label }}</h1>
			<div style="display: flex; gap: 0.75rem; align-items: center; margin-top: 0.5rem;">
				<span class="entity-type-chip entity-type-chip--invoice">INV #{{ invoice_no }}</span>
				<span class="payment-status-badge payment-status-badge--{{ payment_status }}">
					{{ payment_status_label }}
				</span>
			</div>
		</div>
		<div class="entity-detail-header__actions">
			<button onclick="window.print();" class="btn-detail btn-detail--primary btn-print-invoice">
				<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<polyline points="6 9 6 2 18 2 18 9"/>
					<path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/>
					<rect x="6" y="14" width="12" height="8"/>
				</svg>
				Print / Save PDF
			</button>
			{% if logged_in %}
				<a href="{{ path('entity.node.edit_form', {'node': node.id}) }}" class="btn-detail btn-detail--outline">
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
						<path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
					</svg>
					Edit
				</a>
			{% endif %}
		</div>
	</div>

	{# ── TAX INVOICE EXACT FORMAT ── #}
	<div class="indian-tax-invoice">
		
		{# Top line GST No and TAX INVOICE #}
		<div class="invoice-top-bar">
			<span class="invoice-top-gst">Gst No-{{ company_gstin }}</span>
			<span class="invoice-top-title">TAX INVOICE</span>
			<span class="invoice-top-spacer"></span>
		</div>

		{# Banner header box #}
		<div class="invoice-banner-header">
			<div class="banner-logo-box">
				{% if company_logo_url %}
					<img src="{{ company_logo_url }}" class="vendor-logo-image" alt="{{ company_name }} Logo" />
				{% else %}
					{# Styled SVG Logo resembling Santhosh Fabricators #}
					<svg viewBox="0 0 120 100" class="vendor-logo-svg">
						<path d="M20,40 C20,25 35,15 50,15 C65,15 80,25 80,40 L65,40 C65,33 58,28 50,28 C42,28 35,33 35,40 C35,47 42,52 50,52 L50,65 C35,65 20,55 20,40 Z" fill="#C2272D" />
						<path d="M45,45 L75,45 C85,45 90,52 90,62 C90,72 82,78 72,78 L45,78 Z M60,57 L60,67 L70,67 C73,67 75,65 75,62 C75,59 73,57 70,57 Z" fill="#243E8F" />
						<text x="5" y="93" font-size="10" font-weight="bold" fill="#C2272D" font-family="sans-serif">SANTHOSH</text>
						<text x="5" y="101" font-size="8" fill="#243E8F" font-family="sans-serif">FABRICATORS</text>
					</svg>
				{% endif %}
			</div>
			
			<div class="banner-text-box">
				<div class="company-name-strip">
					<h1>{{ company_name }}</h1>
					<div class="diagonal-stripes"></div>
				</div>
				<p class="company-tagline">{{ company_tagline }}</p>
				<p class="company-address">Office address: {{ company_address }}</p>
			</div>
		</div>

		{# Grid Table (To & Bill Details) #}
		<div class="invoice-details-grid-table">
			<div class="details-grid-col details-buyer-col">
				<div class="col-heading-label">To,</div>
				<div class="buyer-company-name">{{ buyer_name }}</div>
				<div class="buyer-address-text">{{ buyer_address|nl2br }}</div>
				<div class="buyer-gstin-row">GSTIN NO : {{ buyer_gstin }}</div>
			</div>
			
			<div class="details-grid-col details-meta-col">
				<table class="meta-inner-table">
					<tr>
						<th>BILL No.</th>
						<td>: {{ invoice_no }}</td>
					</tr>
					<tr>
						<th>BILL DATE</th>
						<td>: {{ invoice_date }}</td>
					</tr>
					<tr>
						<th>Work Order No.</th>
						<td>: {{ work_order_no }}</td>
					</tr>
					<tr>
						<th>Work Order Date</th>
						<td>: {{ work_order_date }}</td>
					</tr>
					<tr>
						<th>GSTN NO.</th>
						<td>: {{ company_gstin }}</td>
					</tr>
					<tr>
						<th>SAC NO.</th>
						<td>: {{ company_sac }}</td>
					</tr>
					<tr>
						<th>PAN NO.</th>
						<td>: {{ company_pan }}</td>
					</tr>
					<tr>
						<th>RA</th>
						<td>: {% if ra_bill_node %}<a href="{{ path('entity.node.canonical', {'node': ra_bill_node.id}) }}" style="color: inherit; text-decoration: underline;">{{ company_ra }}</a>{% else %}{{ company_ra }}{% endif %}</td>
					</tr>
				</table>
			</div>
		</div>

		{# Main Items Table #}
		<table class="invoice-items-formatted-table">
			<thead>
				<tr>
					<th class="col-sr">SR.NO</th>
					<th class="col-desc">DESCRIPTION</th>
					<th class="col-uom">UOM</th>
					<th class="col-qty">QTY</th>
					<th class="col-rate">RATE</th>
					<th class="col-amt">AMOUNT</th>
				</tr>
			</thead>
			<tbody>
				{% for item in invoice_items %}
					<tr class="item-data-row">
						<td class="text-center font-bold">{{ item.sr_no }}</td>
						<td>
							<div class="item-desc-content" style="white-space: pre-line;">{{ item.description }}</div>
						</td>
						<td class="text-center font-medium">{{ item.uom }}</td>
						<td class="text-center font-medium">{{ item.qty }}</td>
						<td class="text-right font-medium">{{ item.rate }}</td>
						<td class="text-right font-bold">{{ item.amount }}</td>
					</tr>
				{% endfor %}
				
				{# Padding rows to ensure spacing matches standard paper format #}
				<tr class="spacer-row"><td colspan="6"></td></tr>

				{# Financial calculations block #}
				<tr class="calc-row">
					<td colspan="4" class="noborder-left noborder-bottom"></td>
					<td class="calc-label">TOTAL AMOUNT</td>
					<td class="calc-val">{{ basic_value_formatted }}</td>
				</tr>
				{% if is_intra_state %}
					<tr class="calc-row">
						<td colspan="4" class="noborder-left noborder-bottom"></td>
						<td class="calc-label">CGST 9%</td>
						<td class="calc-val">{{ cgst_val_formatted }}</td>
					</tr>
					<tr class="calc-row">
						<td colspan="4" class="noborder-left noborder-bottom"></td>
						<td class="calc-label">SGST 9%</td>
						<td class="calc-val">{{ sgst_val_formatted }}</td>
					</tr>
				{% else %}
					<tr class="calc-row">
						<td colspan="4" class="noborder-left noborder-bottom"></td>
						<td class="calc-label">IGST 18%</td>
						<td class="calc-val">{{ igst_val_formatted }}</td>
					</tr>
				{% endif %}
				<tr class="calc-row grand-total-row">
					<td colspan="4" class="noborder-left noborder-bottom"></td>
					<td class="calc-label">TOTAL RECEIVABLE</td>
					<td class="calc-val">{{ total_value_formatted }}</td>
				</tr>
			</tbody>
		</table>

		{# Rupees in words row #}
		<div class="invoice-words-row">
			<div class="words-label">Rs.In Words</div>
			<div class="words-value">{{ total_in_words }}</div>
		</div>

		{# Signatory bottom block #}
		<div class="invoice-bottom-signatory-block">
			<div class="sign-left-pad"></div>
			<div class="sign-right-box">
				<p class="sign-for-company">For {{ company_name }}</p>
				<div class="sign-stamp-area">
					{# Optional Stamp / Signature overlay placeholder #}
				</div>
				<p class="sign-line-label">Authorised Signatory</p>
			</div>
		</div>

		{# Tiny footer line #}
		<div class="invoice-office-footer-line">
			Office : {{ company_address }}
		</div>

	</div>

<style>
.invoice-payment-tracker {
  background: #ffffff;
  border-radius: 12px;
  border: 1px solid #e2e8f0;
  padding: 1.5rem;
  margin-top: 2rem;
  box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05), 0 2px 4px -1px rgba(0,0,0,0.02);
}
.tracker-header {
  border-bottom: 1px solid #f1f5f9;
  padding-bottom: 1rem;
  margin-bottom: 1.5rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.tracker-title {
  font-size: 1.125rem;
  font-weight: 700;
  color: #1e293b;
  display: flex;
  align-items: center;
  gap: 0.5rem;
  margin: 0;
}
.tracker-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 1rem;
  margin-bottom: 2rem;
}
.tracker-card {
  background: #f8fafc;
  border: 1px solid #f1f5f9;
  border-radius: 8px;
  padding: 1rem;
  display: flex;
  flex-direction: column;
}
.tracker-card__label {
  font-size: 0.75rem;
  color: #64748b;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  margin-bottom: 0.25rem;
}
.tracker-card__value {
  font-size: 1.25rem;
  font-weight: 800;
  color: #0f172a;
}
.tracker-card__value--balance {
  color: #2563eb;
}
.tracker-card__value--balance.has-outstanding {
  color: #d97706;
}
.tracker-card__value--balance.has-overdue {
  color: #dc2626;
}
.tracker-card__value--paid {
  color: #16a34a;
}

.payment-status-badge {
  display: inline-flex;
  align-items: center;
  padding: 0.25rem 0.75rem;
  font-size: 0.75rem;
  font-weight: 700;
  border-radius: 9999px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}
.payment-status-badge--pending {
  background-color: #f3f4f6;
  color: #4b5563;
}
.payment-status-badge--partial {
  background-color: #eff6ff;
  color: #2563eb;
}
.payment-status-badge--paid {
  background-color: #dcfce7;
  color: #16a34a;
}
.payment-status-badge--overdue {
  background-color: #fee2e2;
  color: #dc2626;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: .7; }
}

.overdue-banner {
  background: #fff5f5;
  border-left: 4px solid #f56565;
  color: #c53030;
  padding: 1rem;
  border-radius: 8px;
  margin-bottom: 1.5rem;
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 0.75rem;
}
.success-banner {
  background: #f0fff4;
  border-left: 4px solid #48bb78;
  color: #22543d;
  padding: 1rem;
  border-radius: 8px;
  margin-bottom: 1.5rem;
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.tracker-layout {
  display: grid;
  grid-template-columns: 1fr;
  gap: 2rem;
}
@media (min-width: 1024px) {
  .tracker-layout {
    grid-template-columns: 2fr 1fr;
  }
}

.logs-table {
  width: 100%;
  border-collapse: collapse;
  margin-top: 0.5rem;
}
.logs-table th, .logs-table td {
  padding: 0.75rem 1rem;
  text-align: left;
  border-bottom: 1px solid #f1f5f9;
  font-size: 0.875rem;
}
.logs-table th {
  background: #f8fafc;
  color: #475569;
  font-weight: 600;
}
.logs-table tr:last-child td {
  border-bottom: none;
}
.logs-empty {
  text-align: center;
  color: #94a3b8;
  padding: 2rem 0;
  font-style: italic;
  font-size: 0.875rem;
}

.payment-form-card {
  background: #f8fafc;
  border: 1px solid #e2e8f0;
  border-radius: 10px;
  padding: 1.25rem;
}
.payment-form-title {
  font-size: 0.95rem;
  font-weight: 700;
  color: #334155;
  margin-top: 0;
  margin-bottom: 1rem;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}
.form-group {
  margin-bottom: 1rem;
}
.form-group label {
  display: block;
  font-size: 0.75rem;
  font-weight: 600;
  color: #475569;
  margin-bottom: 0.35rem;
}
.form-control {
  width: 100%;
  box-sizing: border-box;
  padding: 0.5rem 0.75rem;
  border: 1px solid #cbd5e1;
  border-radius: 6px;
  font-size: 0.875rem;
  color: #1e293b;
  background-color: #ffffff;
  transition: border-color 0.15s ease-in-out;
}
.form-control:focus {
  border-color: #3b82f6;
  outline: none;
}
.btn-submit-payment {
  width: 100%;
  padding: 0.625rem;
  background-color: #2563eb;
  color: #ffffff;
  border: none;
  border-radius: 6px;
  font-size: 0.875rem;
  font-weight: 600;
  cursor: pointer;
  transition: background-color 0.15s ease-in-out;
}
.btn-submit-payment:hover {
  background-color: #1d4ed8;
}
</style>

	{# ── PAYMENT TRACKING SECTION (NO-PRINT) ── #}
	<div class="invoice-payment-tracker no-print">
		{% if payment_status == 'overdue' %}
			<div class="overdue-banner">
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
					<path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/>
					<line x1="12" y1="9" x2="12" y2="13"/>
					<line x1="12" y1="17" x2="12.01" y2="17"/>
				</svg>
				<span>Warning: This invoice is overdue. Please follow up on the outstanding balance.</span>
			</div>
		{% elseif payment_status == 'paid' %}
			<div class="success-banner">
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
					<polyline points="20 6 9 17 4 12"/>
				</svg>
				<span>Payment completed for Invoice #{{ invoice_no }}. All dues have been collected.</span>
			</div>
		{% endif %}

		<div class="tracker-header">
			<h2 class="tracker-title">
				<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<rect x="2" y="4" width="20" height="16" rx="2"/>
					<line x1="12" y1="8" x2="12" y2="16"/>
					<line x1="8" y1="12" x2="16" y2="12"/>
				</svg>
				Payment Tracking
			</h2>
			<span class="payment-status-badge payment-status-badge--{{ payment_status }}">
				{{ payment_status_label }}
			</span>
		</div>

		<div class="tracker-grid">
			<div class="tracker-card">
				<span class="tracker-card__label">Total Amount</span>
				<span class="tracker-card__value">₹{{ total_value_formatted }}</span>
			</div>
			<div class="tracker-card">
				<span class="tracker-card__label">TDS</span>
				<span class="tracker-card__value">₹{{ tds_amount_formatted }}</span>
				<div style="margin-top: 0.35rem; display: flex; align-items: center; gap: 0.25rem;">
					{% if tds_paid %}
						<span style="display: inline-flex; align-items: center; gap: 4px; font-size: 0.75rem; font-weight: 700; color: #16a34a; background: #ecfdf5; padding: 2px 8px; border-radius: 4px; border: 1px solid #a7f3d0;">
							<span style="font-size: 0.65rem;">●</span> Paid
						</span>
					{% else %}
						<span style="display: inline-flex; align-items: center; gap: 4px; font-size: 0.75rem; font-weight: 700; color: #dc2626; background: #fff5f5; padding: 2px 8px; border-radius: 4px; border: 1px solid #fecdd3;">
							<span style="font-size: 0.65rem;">●</span> Unpaid
						</span>
					{% endif %}
				</div>
			</div>
			<div class="tracker-card">
				<span class="tracker-card__label">Retention</span>
				<span class="tracker-card__value">₹{{ retention_amount_formatted }}</span>
			</div>
			<div class="tracker-card">
				<span class="tracker-card__label">Paid Amount</span>
				<span class="tracker-card__value tracker-card__value--paid">₹{{ paid_amount_formatted }}</span>
			</div>
			<div class="tracker-card">
				<span class="tracker-card__label">Remaining Dues</span>
				<span class="tracker-card__value tracker-card__value--balance {% if remaining_balance_raw > 0.01 %}{% if payment_status == 'overdue' %}has-overdue{% else %}has-outstanding{% endif %}{% endif %}">
					₹{{ remaining_balance_formatted }}
				</span>
			</div>
			<div class="tracker-card">
				<span class="tracker-card__label">Due Date</span>
				<span class="tracker-card__value" {% if payment_status == 'overdue' %}style="color: #dc2626;"{% endif %}>{{ due_date_formatted }}</span>
			</div>
		</div>

		<div class="tracker-layout">
			<div class="payment-logs-card">
				<h3 class="payment-form-title" style="margin-top:0;">
					<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<line x1="8" y1="6" x2="21" y2="6"/>
						<line x1="8" y1="12" x2="21" y2="12"/>
						<line x1="8" y1="18" x2="21" y2="18"/>
						<line x1="3" y1="6" x2="3.01" y2="6"/>
						<line x1="3" y1="12" x2="3.01" y2="12"/>
						<line x1="3" y1="18" x2="3.01" y2="18"/>
					</svg>
					Payment History Logs
				</h3>
				{% if payment_history is not empty %}
					<table class="logs-table">
						<thead>
							<tr>
								<th>Date</th>
								<th>Amount</th>
								<th>Recorded By</th>
								<th>Notes/Remarks</th>
								{% if logged_in %}
									<th style="text-align: center;">Actions</th>
								{% endif %}
							</tr>
						</thead>
						<tbody>
							{% for log in payment_history %}
								<tr>
									<td class="font-medium">{{ log.date }}</td>
									<td class="font-bold">₹{{ log.amount }}</td>
									<td class="text-secondary">{{ log.recorded_by }}</td>
									<td>{{ log.notes ?: '-' }}</td>
									{% if logged_in %}
										<td style="text-align: center; white-space: nowrap;">
											<button class="btn-detail btn-detail--outline edit-log-btn" 
												data-id="{{ log.id }}" 
												data-date="{{ log.date_raw }}" 
												data-amount="{{ log.amount_raw }}" 
												data-notes="{{ log.notes }}"
												style="padding: 0.25rem 0.5rem; font-size: 0.75rem; height: auto; font-family: sans-serif; font-weight: 600; display: inline-block;">
												Edit
											</button>
											<a href="/admin/invoices/{{ node.id }}/payment/{{ log.id }}/delete" 
											   class="btn-detail btn-detail--outline delete-log-btn" 
											   onclick="return confirm('Are you sure you want to delete this payment log entry?');" 
											   style="padding: 0.25rem 0.5rem; font-size: 0.75rem; height: auto; font-family: sans-serif; font-weight: 600; color: #dc2626; border-color: #fecdd3; margin-left: 0.25rem; text-decoration: none; display: inline-block;">
											   Delete
											</a>
										</td>
									{% endif %}
								</tr>
							{% endfor %}
						</tbody>
					</table>
				{% else %}
					<div class="logs-empty">
						No payments have been recorded for this invoice yet.
					</div>
				{% endif %}
			</div>

			{% if logged_in %}
				<div class="payment-form-card">
					<h3 class="payment-form-title">
						<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M12 20h9"/>
							<path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/>
						</svg>
						Record a Payment
					</h3>
					<form action="{{ update_payment_url }}" method="post" class="quick-payment-update-form">
						<div class="form-group">
							<label for="payment_amount">Amount Paid (INR)</label>
							<input type="number" step="0.01" min="0.01" max="{{ remaining_balance_raw }}" name="payment_amount" id="payment_amount" class="form-control" placeholder="0.00" required>
						</div>
						<div class="form-group">
							<label for="tds">TDS Amount (INR)</label>
							<div style="display: flex; gap: 0.5rem; align-items: center;">
								<input type="number" step="0.01" min="0.00" name="tds" id="tds" class="form-control" value="{{ tds_amount_raw }}" placeholder="0.00" style="flex: 1;">
								<button type="button" id="btn-autofill-tds" class="btn-detail btn-detail--outline" style="height: 36px; padding: 0 10px; font-size: 0.8rem; font-family: sans-serif; white-space: nowrap;">Autofill 2%</button>
							</div>
						</div>
						<div class="form-group" style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1rem; margin-top: 0.5rem;">
							<input type="checkbox" name="tds_paid" id="tds_paid" value="1" {% if tds_paid %}checked{% endif %} style="width: 16px; height: 16px; cursor: pointer;">
							<label for="tds_paid" style="margin: 0; font-weight: 600; font-size: 0.825rem; color: #475569; cursor: pointer; display: inline-block;">TDS is Paid</label>
						</div>
						<div class="form-group">
							<label for="retention">Retention Amount (INR)</label>
							<input type="number" step="0.01" min="0.00" name="retention" id="retention" class="form-control" value="{{ retention_amount_raw }}" placeholder="0.00">
						</div>
						<div class="form-group">
							<label for="payment_date">Payment Date</label>
							<input type="date" name="payment_date" id="payment_date" class="form-control" value="{{ "now"|date("Y-m-d") }}" required>
						</div>
						<div class="form-group">
							<label for="notes">Notes / Reference No</label>
							<input type="text" name="notes" id="notes" class="form-control" placeholder="e.g. Bank transfer ref #123">
						</div>
						<button type="submit" class="btn-submit-payment">Add Payment Entry</button>
					</form>
				</div>
				<script>
				document.addEventListener('DOMContentLoaded', function() {
					const tdsInput = document.getElementById('tds');
					const autofillBtn = document.getElementById('btn-autofill-tds');
					const basicAmount = parseFloat('{{ basic_value_raw }}') || 0;
					const computedTds = (basicAmount * 0.02).toFixed(2);

					// Autofill on load if TDS is empty or zero
					if (tdsInput && (tdsInput.value === '' || parseFloat(tdsInput.value) === 0)) {
						tdsInput.value = computedTds;
					}

					// Autofill button handler
					if (autofillBtn && tdsInput) {
						autofillBtn.addEventListener('click', function(e) {
							e.preventDefault();
							tdsInput.value = computedTds;
						});
					}
				});
				</script>

				{# ── EDIT PAYMENT MODAL ── #}
				<div id="edit-payment-modal" class="payment-modal-overlay" style="display: none;">
					<div class="payment-modal-card">
						<div class="payment-modal-header">
							<h3 class="payment-modal-title">Edit Payment Entry</h3>
							<button type="button" class="close-modal-btn">&times;</button>
						</div>
						<form id="edit-payment-form" action="" method="post" class="quick-payment-update-form">
							<div class="form-group">
								<label for="edit_payment_amount">Amount Paid (INR)</label>
								<input type="number" step="0.01" min="0.01" name="payment_amount" id="edit_payment_amount" class="form-control" required>
							</div>
							<div class="form-group">
								<label for="edit_payment_date">Payment Date</label>
								<input type="date" name="payment_date" id="edit_payment_date" class="form-control" required>
							</div>
							<div class="form-group">
								<label for="edit_notes">Notes / Reference No</label>
								<input type="text" name="notes" id="edit_notes" class="form-control">
							</div>
							<div style="display: flex; gap: 0.5rem; margin-top: 1.5rem;">
								<button type="submit" class="btn-submit-payment" style="flex: 1;">Save Changes</button>
								<button type="button" class="btn-detail btn-detail--outline cancel-modal-btn" style="flex: 1;">Cancel</button>
							</div>
						</form>
					</div>
				</div>

				<style>
				.payment-modal-overlay {
					position: fixed;
					top: 0;
					left: 0;
					width: 100%;
					height: 100%;
					background: rgba(15, 23, 42, 0.6);
					backdrop-filter: blur(4px);
					display: flex;
					align-items: center;
					justify-content: center;
					z-index: 10000;
				}
				.payment-modal-card {
					background: #ffffff;
					border-radius: 12px;
					width: 100%;
					max-width: 450px;
					box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
					padding: 1.5rem;
					box-sizing: border-box;
					border: 1px solid #e2e8f0;
				}
				.payment-modal-header {
					display: flex;
					justify-content: space-between;
					align-items: center;
					margin-bottom: 1.25rem;
					border-bottom: 1px solid #f1f5f9;
					padding-bottom: 0.75rem;
				}
				.payment-modal-title {
					margin: 0;
					font-size: 1.1rem;
					font-weight: 700;
					color: #0f172a;
				}
				.close-modal-btn {
					background: transparent;
					border: none;
					font-size: 1.5rem;
					color: #64748b;
					cursor: pointer;
					line-height: 1;
					padding: 0;
				}
				.close-modal-btn:hover {
					color: #0f172a;
				}
				</style>

				<script>
				document.addEventListener('DOMContentLoaded', function() {
					const modal = document.getElementById('edit-payment-modal');
					const form = document.getElementById('edit-payment-form');
					const amountInput = document.getElementById('edit_payment_amount');
					const dateInput = document.getElementById('edit_payment_date');
					const notesInput = document.getElementById('edit_notes');
					
					const editButtons = document.querySelectorAll('.edit-log-btn');
					const closeButtons = document.querySelectorAll('.close-modal-btn, .cancel-modal-btn');

					editButtons.forEach(btn => {
						btn.addEventListener('click', function() {
							const id = this.getAttribute('data-id');
							const date = this.getAttribute('data-date');
							const amount = this.getAttribute('data-amount');
							const notes = this.getAttribute('data-notes');

							// Set form action dynamically
							form.action = `/admin/invoices/{{ node.id }}/payment/` + id + `/edit`;
							
							// Prefill inputs
							amountInput.value = amount;
							dateInput.value = date;
							notesInput.value = notes;

							// Show modal
							modal.style.display = 'flex';
						});
					});

					closeButtons.forEach(btn => {
						btn.addEventListener('click', function() {
							modal.style.display = 'none';
						});
					});

					// Close modal on outside click
					modal.addEventListener('click', function(e) {
						if (e.target === modal) {
							modal.style.display = 'none';
						}
					});
				});
				</script>
			{% endif %}
		</div>
	</div>

	{# ── BACK LINK ── #}
	<div class="entity-back-link no-print">
		{% if node.field_purchase_order.entity %}
			<a href="{{ path('entity.node.canonical', {'node': node.field_purchase_order.target_id}) }}" class="btn-detail btn-detail--outline">
				<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<line x1="19" y1="12" x2="5" y2="12"/>
					<polyline points="12 19 5 12 12 5"/>
				</svg>
				Back to {{ node.field_purchase_order.entity.label }}
			</a>
		{% else %}
			<a href="/projects" class="btn-detail btn-detail--outline">
				<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<line x1="19" y1="12" x2="5" y2="12"/>
					<polyline points="12 19 5 12 12 5"/>
				</svg>
				Back to Projects
			</a>
		{% endif %}
	</div>

</div>

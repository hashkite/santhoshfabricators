{#
/**
 * @file
 * Invoice Payment Tracking Dashboard template.
 */
#}
<div
	class="admin-dashboard invoice-tracking-dashboard">

	{# ── PRINT ONLY HEADER ── #}
	<div class="print-only-header">
		<h1 style="margin: 0 0 1rem 0; font-size: 1.75rem; font-family: 'Outfit', sans-serif; font-weight: 800; color: #0f172a; border-bottom: 2px solid #334155; padding-bottom: 0.5rem;">Invoice Payment Tracking Report</h1>
	</div>

	{# ── DASHBOARD HEADER ── #}
	<div class="dashboard-overview-header">
		<div class="dashboard-overview-header__left">
			<p class="dashboard-overview-subtitle">Track payments, monitoring collections, overdue items, and outstanding client balances.</p>
		</div>
		<div class="dashboard-overview-header__right" style="display: flex; gap: 0.75rem; align-items: center;">
			<a href="/admin/invoices/tracking?export=excel&search={{ filters.search }}&status={{ filters.status }}&due_date={{ filters.due_date }}&project={{ filters.project }}&invoice_no={{ filters.invoice_no }}&po_no={{ filters.po_no }}&month={{ filters.month }}&retention={{ filters.retention }}" class="btn-csv-download btn-detail btn-detail--primary btn-export-excel">
				<svg width="16" height="16" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
					<line x1="3" y1="9" x2="21" y2="9"/>
					<line x1="9" y1="21" x2="9" y2="9"/>
				</svg>
				Export Excel
			</a>
			<button onclick="window.print();" class="btn-csv-download btn-detail btn-detail--primary btn-export-pdf">
				<svg width="16" height="16" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
					<polyline points="6 9 6 2 18 2 18 9"/>
					<path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/>
					<rect x="6" y="14" width="12" height="8"/>
				</svg>
				Export PDF
			</button>
		</div>
	</div>

	{# ── KPI STAT CARDS ROW ── #}
	<div class="kpi-cards-row">
		<div class="kpi-card">
			<div class="kpi-card__header">
				<span class="kpi-card__label">TOTAL INVOICED</span>
				<div class="kpi-card__icon kpi-card__icon--blue">
					<svg width="20" height="20" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
				</div>
			</div>
			<div class="kpi-card__body">
				<span class="kpi-card__value">{{ kpis.total_invoiced }}</span>
			</div>
		</div>

		<div class="kpi-card">
			<div class="kpi-card__header">
				<span class="kpi-card__label">TOTAL COLLECTED</span>
				<div class="kpi-card__icon kpi-card__icon--green">
					<svg width="20" height="20" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
				</div>
			</div>
			<div class="kpi-card__body">
				<span class="kpi-card__value" style="color: #16a34a;">{{ kpis.total_collected }}</span>
			</div>
		</div>

		<div class="kpi-card">
			<div class="kpi-card__header">
				<span class="kpi-card__label">TOTAL OUTSTANDING</span>
				<div class="kpi-card__icon kpi-card__icon--amber">
					<svg width="20" height="20" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
				</div>
			</div>
			<div class="kpi-card__body">
				<span class="kpi-card__value" style="color: #2563eb;">{{ kpis.total_outstanding }}</span>
			</div>
		</div>

		<div class="kpi-card">
			<div class="kpi-card__header">
				<span class="kpi-card__label">TOTAL RETENTION</span>
				<div class="kpi-card__icon kpi-card__icon--orange">
					<svg width="20" height="20" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
				</div>
			</div>
			<div class="kpi-card__body">
				<span class="kpi-card__value" style="color: #d97706;">{{ kpis.total_retention }}</span>
			</div>
		</div>

		<div class="kpi-card">
			<div class="kpi-card__header">
				<span class="kpi-card__label">OVERDUE INVOICES</span>
				<div class="kpi-card__icon kpi-card__icon--purple">
					<svg width="20" height="20" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
				</div>
			</div>
			<div class="kpi-card__body">
				<span class="kpi-card__value" style="color: #dc2626;">{{ kpis.overdue_count }}</span>
			</div>
		</div>
	</div>

	{# ── FILTERS BAR ── #}
	<div class="tracking-filters-widget">
		<form method="get" action="/admin/invoices/tracking" class="tracking-filters-form">
			<div class="tracking-filters-grid">

				<div class="tracking-filter-group">
					<label for="project" class="tracking-filter-label">Project Site</label>
					<select name="project" id="project" class="tracking-filter-control">
						<option value="">- All Projects -</option>
						{% for id, title in projects_list %}
							<option value="{{ id }}" {% if filters.project == id %} selected {% endif %}>{{ title }}</option>
						{% endfor %}
					</select>
				</div>

				<div class="tracking-filter-group">
					<label for="invoice_no" class="tracking-filter-label">Invoice No.</label>
					<input type="text" name="invoice_no" id="invoice_no" class="tracking-filter-control" placeholder="Search Invoice No." value="{{ filters.invoice_no }}">
				</div>

				<div class="tracking-filter-group">
					<label for="po_no" class="tracking-filter-label">PO Number</label>
					<input type="text" name="po_no" id="po_no" class="tracking-filter-control" placeholder="Search PO Number" value="{{ filters.po_no }}">
				</div>

				<div class="tracking-filter-group">
					<label for="month" class="tracking-filter-label">Month</label>
					<select name="month" id="month" class="tracking-filter-control">
						<option value="">- All Months -</option>
						{% for opt in month_options %}
							<option value="{{ opt.value }}" {% if filters.month == opt.value %} selected {% endif %}>{{ opt.label }}</option>
						{% endfor %}
					</select>
				</div>

				<div class="tracking-filter-group">
					<label for="status" class="tracking-filter-label">Payment Status</label>
					<select name="status" id="status" class="tracking-filter-control">
						<option value="">- All Statuses -</option>
						<option value="pending" {% if filters.status == 'pending' %} selected {% endif %}>Pending</option>
						<option value="partial" {% if filters.status == 'partial' %} selected {% endif %}>Partial</option>
						<option value="paid" {% if filters.status == 'paid' %} selected {% endif %}>Paid</option>
						<option value="overdue" {% if filters.status == 'overdue' %} selected {% endif %}>Overdue</option>
					</select>
				</div>

				<div class="tracking-filter-group">
					<label for="due_date" class="tracking-filter-label">Due Date Period</label>
					<select name="due_date" id="due_date" class="tracking-filter-control">
						<option value="">- All Dues -</option>
						<option value="overdue" {% if filters.due_date == 'overdue' %} selected {% endif %}>Overdue Payments</option>
						<option value="this_week" {% if filters.due_date == 'this_week' %} selected {% endif %}>Due Within 7 Days</option>
						<option value="this_month" {% if filters.due_date == 'this_month' %} selected {% endif %}>Due Within 30 Days</option>
					</select>
				</div>

				<div class="tracking-filter-group">
					<label for="retention" class="tracking-filter-label">Retention</label>
					<select name="retention" id="retention" class="tracking-filter-control">
						<option value="">- All -</option>
						<option value="yes" {% if filters.retention == 'yes' %} selected {% endif %}>With Retention</option>
						<option value="no" {% if filters.retention == 'no' %} selected {% endif %}>Without Retention</option>
					</select>
				</div>

				<div class="tracking-filter-group tracking-filter-group--wide">
					<label for="search" class="tracking-filter-label">Quick Search (All fields)</label>
					<input type="text" name="search" id="search" class="tracking-filter-control" placeholder="Search Client, Invoice, PO" value="{{ filters.search }}">
				</div>

				<div class="tracking-filter-actions">
					<button type="submit" class="btn-apply-filters btn-detail btn-detail--primary">
						<svg width="14" height="14" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
						Apply Filters
					</button>
					<a href="/admin/invoices/tracking" class="btn-reset-filters btn-detail btn-detail--outline">Reset</a>
				</div>

			</div>
		</form>
	</div>

	{# ── REPORT TABLE WIDGET ── #}
	<div class="dashboard-widget">
		<div class="dashboard-widget__header">
			<h2 class="dashboard-widget__title" style="margin: 0; font-size: 1.1rem;">Invoices Overview</h2>
		</div>
		<div class="dashboard-widget__body dashboard-widget__body--table" style="overflow-x: auto;">
			{% if rows is not empty %}
				<table class="activity-table tracking-report-table" style="min-width: 1350px;">
					<thead>
						<tr>
							<th>INVOICE NO</th>
							<th>CLIENT / PROJECT</th>
							<th>PO NUMBER</th>
							<th style="text-align: center;">RA BILL</th>
							<th>DATE</th>
							<th style="text-align: right;">BASIC VALUE</th>
							<th style="text-align: right;">GST(18%)</th>
							<th style="text-align: right;">TOTAL VALUE</th>
							<th style="text-align: right;">TDS(2%)</th>
							<th style="text-align: right;">RETENTION</th>
							<th style="text-align: right;">NET RECEIVABLE</th>
							<th style="text-align: right;">TOTAL PAID</th>
							<th style="text-align: right;">DUE BALANCE</th>
							<th style="text-align: center;">DUE DATE</th>
							<th style="text-align: center;">STATUS</th>
						</tr>
					</thead>
					<tbody>
						{% for row in rows %}
							<tr>
								<td style="white-space: nowrap;">
									<a href="/node/{{ row.id }}" class="activity-entity-link" style="font-weight: 700; color: #2563eb; text-decoration: none;">{{ row.invoice_no }}</a>
								</td>
								<td>
									<div style="font-weight: 600; color: #1e293b;">{{ row.client }}</div>
									<div style="font-size: 0.75rem; color: #64748b; white-space: nowrap;">
										Project:
										{% if row.project_id %}
											<a href="/node/{{ row.project_id }}" style="color: #2563eb; text-decoration: none; font-weight: 600;">{{ row.project }}</a>
										{% else %}
											{{ row.project ?: '-' }}
										{% endif %}
									</div>
								</td>
								<td style="white-space: nowrap;">
									{% if row.po_id %}
										<a href="/node/{{ row.po_id }}" style="color: #2563eb; text-decoration: none; font-weight: 600; font-size: 0.85rem;">{{ row.po_no }}</a>
									{% else %}
										<span style="color: #475569; font-weight: 550; font-size: 0.85rem;">{{ row.po_no }}</span>
									{% endif %}
								</td>
								<td style="text-align: center; white-space: nowrap;">
									<span class="ra-badge">
										{{ row.ra_num }}
									</span>
								</td>
								<td style="color: #475569; font-size: 0.85rem; white-space: nowrap;">{{ row.date }}</td>
								<td class="col-monospaced col-basic" style="text-align: right; white-space: nowrap;">{{ row.basic }}</td>
								<td class="col-monospaced col-gst" style="text-align: right; white-space: nowrap;">{{ row.gst }}</td>
								<td class="col-monospaced col-total" style="text-align: right; white-space: nowrap;">{{ row.total }}</td>
								<td class="col-monospaced col-tds" style="text-align: right; white-space: nowrap;">
									{{ row.tds }}
									<div style="font-size: 0.65rem; margin-top: 2px; text-align: right; font-family: 'Plus Jakarta Sans', sans-serif;">
										{% if row.tds_paid %}
											<span style="color: #16a34a; font-weight: 700;">● Paid</span>
										{% else %}
											<span style="color: #dc2626; font-weight: 700;">● Unpaid</span>
										{% endif %}
									</div>
								</td>
								<td class="col-monospaced col-retention" style="text-align: right; white-space: nowrap;">{{ row.retention }}</td>
								<td class="col-monospaced col-expected" style="text-align: right; white-space: nowrap;">{{ row.expected }}</td>
								<td class="col-monospaced col-paid" style="text-align: right; white-space: nowrap;">{{ row.paid }}</td>
								<td class="col-monospaced col-balance" style="text-align: right; white-space: nowrap;">{{ row.balance }}</td>
								<td style="text-align: center; font-size: 0.85rem; font-weight: 600; white-space: nowrap; {% if row.is_overdue %}color: #dc2626; font-weight: 700;{% else %}color: #475569;{% endif %}">
									{{ row.due_date }}
								</td>
								<td style="text-align: center; white-space: nowrap;">
									<span class="payment-status-badge payment-status-badge--{{ row.status }}">
										{{ row.status_label }}
									</span>
								</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>
			{% else %}
				<div style="padding: 3rem; text-align: center; color: #64748b; font-style: italic;">
					No invoices match the specified filter criteria.
				</div>
			{% endif %}
		</div>
	</div>

</div>

<style>
	/* Font import for a professional, premium visual experience */
	@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');

	.invoice-tracking-dashboard {
		font-family: 'Plus Jakarta Sans', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
		color: #1e293b;
		max-width: 1400px;
		margin: 0 auto;
		padding: 0; /* Remove padding to merge with system layout margins */
	}

	.invoice-tracking-dashboard .print-only-header {
		display: none !important;
	}

	/* Header Enhancements */
	.invoice-tracking-dashboard .dashboard-overview-header {
		border-bottom: 2px solid #f1f5f9;
		padding-bottom: 1.5rem;
		margin-bottom: 2.5rem;
		display: flex !important;
		justify-content: space-between !important;
		align-items: center !important;
		flex-wrap: wrap !important;
		gap: 1rem !important;
		box-sizing: border-box !important;
	}
	.invoice-tracking-dashboard .dashboard-overview-header__left {
		flex: 1 !important;
		min-width: 280px !important;
	}
	.invoice-tracking-dashboard .dashboard-overview-subtitle {
		font-size: 0.95rem;
		color: #64748b;
		margin: 0;
		font-weight: 500;
	}

	/* Download CSV button styling */
	.invoice-tracking-dashboard .btn-csv-download {
		background: linear-gradient(135deg, #10b981 0%, #059669 100%) !important;
		color: #ffffff !important;
		font-family: 'Outfit', sans-serif;
		font-weight: 700 !important;
		padding: 0.75rem 1.5rem !important;
		border-radius: 8px !important;
		box-shadow: 0 4px 12px rgba(16, 185, 129, 0.2) !important;
		transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1) !important;
		border: none !important;
		display: inline-flex !important;
		align-items: center !important;
		gap: 0.5rem !important;
		text-decoration: none !important;
	}
	.invoice-tracking-dashboard .btn-csv-download:hover {
		transform: translateY(-2px);
		box-shadow: 0 6px 16px rgba(16, 185, 129, 0.3) !important;
		background: linear-gradient(135deg, #059669 0%, #047857 100%) !important;
	}
	.invoice-tracking-dashboard .btn-csv-download:active {
		transform: translateY(0);
	}

	/* Stat Cards Enhancements */
	.invoice-tracking-dashboard .kpi-cards-row {
		display: grid !important;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)) !important;
		gap: 1.5rem !important;
		margin-bottom: 2.5rem !important;
	}
	.invoice-tracking-dashboard .kpi-card {
		background: #ffffff !important;
		border: 1px solid #e2e8f0 !important;
		border-radius: 16px !important;
		padding: 1.5rem !important;
		box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.02) !important;
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
		position: relative !important;
		overflow: hidden !important;
		box-sizing: border-box !important;
	}
	.invoice-tracking-dashboard .kpi-card::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 4px;
		background: transparent;
	}
	.invoice-tracking-dashboard .kpi-card:hover {
		transform: translateY(-4px) !important;
		box-shadow: 0 12px 20px -8px rgba(0, 0, 0, 0.1) !important;
		border-color: #cbd5e1 !important;
	}

	/* Card custom top borders */
	.invoice-tracking-dashboard .kpi-card:nth-child(1)::before {
		background: linear-gradient(90deg, #3b82f6, #60a5fa);
	}
	.invoice-tracking-dashboard .kpi-card:nth-child(2)::before {
		background: linear-gradient(90deg, #10b981, #34d399);
	}
	.invoice-tracking-dashboard .kpi-card:nth-child(3)::before {
		background: linear-gradient(90deg, #f59e0b, #fbbf24);
	}
	.invoice-tracking-dashboard .kpi-card:nth-child(4)::before {
		background: linear-gradient(90deg, #ea580c, #f97316);
	}
	.invoice-tracking-dashboard .kpi-card:nth-child(5)::before {
		background: linear-gradient(90deg, #ef4444, #f87171);
	}

	.invoice-tracking-dashboard .kpi-card__header {
		display: flex !important;
		justify-content: space-between !important;
		align-items: center !important;
		margin-bottom: 1rem !important;
	}
	.invoice-tracking-dashboard .kpi-card__label {
		font-size: 0.75rem !important;
		font-weight: 800 !important;
		color: #64748b !important;
		text-transform: uppercase !important;
		letter-spacing: 0.05em !important;
	}
	.invoice-tracking-dashboard .kpi-card__icon {
		width: 42px !important;
		height: 42px !important;
		border-radius: 12px !important;
		display: flex !important;
		align-items: center !important;
		justify-content: center !important;
		transition: all 0.2s ease !important;
	}
	.invoice-tracking-dashboard .kpi-card__icon--blue {
		background-color: #eff6ff !important;
		color: #2563eb !important;
	}
	.invoice-tracking-dashboard .kpi-card__icon--green {
		background-color: #ecfdf5 !important;
		color: #059669 !important;
	}
	.invoice-tracking-dashboard .kpi-card__icon--amber {
		background-color: #fffbeb !important;
		color: #d97706 !important;
	}
	.invoice-tracking-dashboard .kpi-card__icon--orange {
		background-color: #fff7ed !important;
		color: #ea580c !important;
	}
	.invoice-tracking-dashboard .kpi-card__icon--purple {
		background-color: #fef2f2 !important;
		color: #dc2626 !important;
	}
	.invoice-tracking-dashboard .kpi-card__value {
		font-family: 'Outfit', sans-serif !important;
		font-size: 2rem !important;
		font-weight: 800 !important;
		line-height: 1 !important;
	}

	/* Isolated Filters Bar Styling to bypass admin theme overrides */
	.invoice-tracking-dashboard .tracking-filters-widget {
		background: #ffffff !important;
		border: 1px solid #e2e8f0 !important;
		border-radius: 16px !important;
		padding: 1.5rem !important;
		box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05) !important;
		margin-bottom: 2.5rem !important;
		display: block !important;
		width: 100% !important;
		box-sizing: border-box !important;
	}

	.invoice-tracking-dashboard .tracking-filters-form {
		display: block !important;
		width: 100% !important;
		margin: 0 !important;
		padding: 0 !important;
	}

	.invoice-tracking-dashboard .tracking-filters-grid {
		display: grid !important;
		grid-template-columns: repeat(4, 1fr) !important;
		gap: 1.25rem !important;
		align-items: end !important;
		width: 100% !important;
		box-sizing: border-box !important;
	}

	@media(min-width: 1025px) {
		.invoice-tracking-dashboard .tracking-filter-group--wide {
			grid-column: span 2 !important;
		}
		.invoice-tracking-dashboard .tracking-filter-actions {
			grid-column: span 2 !important;
		}
	}

	@media(max-width: 1024px) {
		.invoice-tracking-dashboard .tracking-filters-grid {
			grid-template-columns: repeat(2, 1fr) !important;
		}
	}

	@media(max-width: 640px) {
		.invoice-tracking-dashboard .tracking-filters-grid {
			grid-template-columns: 1fr !important;
		}
	}

	.invoice-tracking-dashboard .tracking-filter-group {
		display: flex !important;

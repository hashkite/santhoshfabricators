  if (isset($form['field_basic_value_gst'])) {
    $response->addCommand(new ReplaceCommand('#invoice-gst-wrapper', $form['field_basic_value_gst']));
  }

  return $response;
}

/**
 * AJAX callback to return updated basic value and basic value + GST fields for invoices.
 */
function power_alpha_helper_invoice_items_ajax_callback(array &$form, FormStateInterface $form_state)
{
  $response = new AjaxResponse();

  if (isset($form['field_basic_value'])) {
    $response->addCommand(new ReplaceCommand('#invoice-basic-value-wrapper', $form['field_basic_value']));
  }

  if (isset($form['field_basic_value_gst'])) {
    $response->addCommand(new ReplaceCommand('#invoice-gst-wrapper', $form['field_basic_value_gst']));
  }

  return $response;
}
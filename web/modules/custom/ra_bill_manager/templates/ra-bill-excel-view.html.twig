<style>
	.ra-excel-container {
		font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
		margin: 20px 0;
		color: var(--pa-text, #263238);
	}

	/* Action Buttons */
	.ra-header-actions {
		display: flex;
		justify-content: flex-end;
		align-items: center;
		gap: 12px;
		position: sticky;
		top: var(--drupal-displace-offset-top, 0px);
		z-index: 110;
		background-color: var(--pa-bg, #F8F9FA);
		padding: 12px 16px;
		margin-bottom: 0;
		border-bottom: 1px solid var(--pa-border, rgba(0, 145, 234, 0.12));
		box-shadow: var(--pa-shadow-sm);
		border-radius: var(--pa-radius-lg, 16px) var(--pa-radius-lg, 16px) 0 0;
	}
	.ra-btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 10px 18px;
		border-radius: var(--pa-radius-sm, 8px);
		font-family: 'Inter', system-ui, sans-serif;
		font-weight: 600;
		font-size: 13px;
		text-decoration: none;
		border: none;
		cursor: pointer;
		transition: transform var(--pa-transition, 0.25s), background-color var(--pa-transition, 0.25s), box-shadow var(--pa-transition, 0.25s);
		gap: 6px;
	}
	.ra-btn:hover {
		transform: translateY(-1px);
	}
	.ra-btn:active {
		transform: translateY(0);
	}
	.ra-btn-export {
		background-color: #15803d;
		color: white !important;
		box-shadow: 0 2px 4px rgba(21, 128, 61, 0.15);
	}
	.ra-btn-export:hover {
		background-color: #166534;
		color: white !important;
		box-shadow: 0 4px 8px rgba(21, 128, 61, 0.25);
	}
	.ra-btn-invoice {
		background-color: var(--pa-primary-dark, #0277BD); /* Shifted to dark primary blue to pass contrast requirements */
		color: white !important;
		box-shadow: 0 2px 4px rgba(2, 119, 189, 0.15);
	}
	.ra-btn-invoice:hover {
		background-color: #01579b;
		color: white !important;
		box-shadow: 0 4px 8px rgba(2, 119, 189, 0.25);
	}
	.ra-btn-save {
		background-color: #a16207;
		color: white !important;
		box-shadow: 0 2px 4px rgba(161, 98, 7, 0.15);
	}
	.ra-btn-save:hover {
		background-color: #854d0e;
		color: white !important;
		box-shadow: 0 4px 8px rgba(161, 98, 7, 0.25);
	}
	.ra-btn-save:disabled {
		background-color: var(--pa-text-faint, #ADB5BD);
		cursor: not-allowed;
		box-shadow: none;
		transform: none;
	}
	.ra-btn-save.saving {
		animation: pulse 1s infinite;
	}
	@keyframes pulse {
		0,
		100% {
			opacity: 1;
		}
		50% {
			opacity: 0.6;
		}
	}
	.ra-btn-next {
		background-color: #4f46e5;
		color: white !important;
		box-shadow: 0 2px 4px rgba(79, 70, 229, 0.15);
	}
	.ra-btn-next:hover {
		background-color: #4338ca;
		color: white !important;
		box-shadow: 0 4px 8px rgba(79, 70, 229, 0.25);
	}
	.ra-qty-input.over-claimed {
		border-color: #dc2626 !important;
		background: #fee2e2 !important;
		color: #dc2626 !important;
	}

	/* ── ABSTRACT SHEET WRAPPER ── */
	.ra-abstract-sheet {
		border: 1px solid var(--pa-border, rgba(0, 145, 234, 0.12));
		border-radius: 0 0 var(--pa-radius-lg, 16px) var(--pa-radius-lg, 16px);
		overflow: hidden;
		box-shadow: var(--pa-shadow-md);
		background: var(--pa-surface, #fff);
	}

	/* ── VENDOR NAME BANNER ── */
	.ra-vendor-banner {
		background: var(--pa-surface, #fff);
		text-align: center;
		padding: 12px 16px 8px;
		border-bottom: 1px solid var(--pa-border, rgba(0, 145, 234, 0.12));
		font-size: 16px;
		font-weight: 800;
		color: var(--pa-text, #263238);
		letter-spacing: 1px;
		text-transform: uppercase;
		font-family: 'Manrope', system-ui, sans-serif;
	}

	/* ── HEADER INFO ROWS ── */
	.ra-info-row {
		display: flex;
		border-bottom: 1px solid var(--pa-border, rgba(0, 145, 234, 0.12));
		font-size: 12px;
		font-weight: 600;
		color: var(--pa-text, #263238);
		background: var(--pa-surface, #fff);
	}
	.ra-info-cell {
		padding: 8px 12px;
		border-right: 1px solid var(--pa-border, rgba(0, 145, 234, 0.12));
		display: flex;
		align-items: center;
		gap: 6px;
	}
	.ra-info-cell:last-child {
		border-right: none;
	}
	.ra-info-label {
		color: var(--pa-text-muted, #455A64);
		white-space: nowrap;
		font-weight: 700;
		text-transform: uppercase;
		font-size: 11px;
		letter-spacing: 0.5px;
	}
	.ra-info-value {
		color: var(--pa-text, #263238);
		font-weight: 600;
		font-size: 13px;
	}
	.ra-info-cell--grow {
		flex: 1;
	}

	/* ── ABSTRACT LABEL ── */
	.ra-abstract-label {
		text-align: center;
		padding: 6px;
		font-weight: 800;
		font-size: 12px;
		color: var(--pa-text, #263238);
		border-bottom: 1px solid var(--pa-border, rgba(0, 145, 234, 0.12));
		text-transform: uppercase;
		letter-spacing: 1px;
		background: var(--pa-bg, #f8f9fa);
		font-family: 'Manrope', system-ui, sans-serif;
	}

	/* ── DATA TABLE ── */
	.ra-sheet-wrapper {
		overflow-x: auto !important;
		width: 100% !important;
	}
	.ra-sheet-wrapper table.ra-sheet-table {
		display: table !important;
		width: 100% !important;
		border-collapse: collapse !important;
		background-color: white !important;
		font-size: 12px !important;
		table-layout: auto !important;
		float: none !important;
		margin: 0 !important;
		padding: 0 !important;
	}
	.ra-sheet-wrapper table.ra-sheet-table thead {
		display: table-header-group !important;
		float: none !important;
	}
	.ra-sheet-wrapper table.ra-sheet-table tbody {
		display: table-row-group !important;
		float: none !important;
	}
	.ra-sheet-wrapper table.ra-sheet-table tfoot {
		display: table-footer-group !important;
		float: none !important;
	}
	.ra-sheet-wrapper table.ra-sheet-table tr {
		display: table-row !important;
		float: none !important;
		width: auto !important;
		height: auto !important;
		background-color: transparent !important;
	}
	.ra-sheet-wrapper table.ra-sheet-table th {
		display: table-cell !important;
		width: auto !important;
		max-width: none !important;
		min-width: none !important;
		float: none !important;
		flex: none !important;
		background: #0277BD;
		color: white !important;
		font-weight: 700 !important;
		padding: 10px 12px !important;
		text-align: center !important;
		border: 1px solid var(--pa-border, rgba(0, 145, 234, 0.12)) !important;
		white-space: nowrap !important;
		vertical-align: middle !important;
		font-size: 11px !important;
		text-transform: uppercase !important;
		letter-spacing: 0.5px !important;
	}
	.ra-sheet-wrapper table.ra-sheet-table th.highlight-header {
		background: #d97706 !important;
	}

	.ra-sheet-wrapper table.ra-sheet-table td {
		display: table-cell !important;
		width: auto !important;
		max-width: none !important;
		min-width: none !important;
		float: none !important;
		flex: none !important;
		padding: 8px 12px !important;
		border: 1px solid var(--pa-border-light, rgba(0, 145, 234, 0.06)) !important;
		vertical-align: middle !important;
		background-color: transparent !important;
		white-space: normal !important;
		font-size: 12px !important;
		color: var(--pa-text, #263238) !important;
		transition: background-color var(--pa-transition, 0.25s) ease;
	}
	.ra-sheet-table tr:nth-child(even) td {
		background-color: rgba(0, 145, 234, 0.02) !important;
	}
	.ra-sheet-table tr:hover td {
		background-color: rgba(0, 145, 234, 0.04) !important;
	}

	/* Disable any responsive pseudo-element labels */
	.ra-sheet-table td::before,
	.ra-sheet-table td::after,
	.ra-sheet-table th::before,
	.ra-sheet-table th::after {
		display: none !important;
		content: "" !important;
	}

	/* Header spanning groups */
	.ra-sheet-table th.group-header {
		background: #0277BD;
		font-size: 12px !important;
		letter-spacing: 0.5px !important;
	}

	/* Alignments */
	.align-right {
		text-align: right !important;
	}
	.align-center {
		text-align: center !important;
	}
	.align-left {
		text-align: left !important;
	}
	.text-bold {
		font-weight: 700 !important;
	}

	/* Yellow highlight for "IN THIS BILL" column */
	.highlight-cell {
		background-color: rgba(245, 158, 11, 0.05) !important;
		font-weight: 700 !important;
		color: var(--pa-text, #263238) !important;
	}
	.ra-sheet-table tr:hover .highlight-cell {
		background-color: rgba(245, 158, 11, 0.1) !important;
	}

	/* Totals row */
	.ra-totals-row {
		display: table-row !important;
		background-color: var(--pa-bg, #f1f5f9) !important;
		font-weight: 700 !important;
		border-top: 2px solid var(--pa-border, rgba(0, 145, 234, 0.12)) !important;
	}
	.ra-totals-row td {
		font-weight: 700 !important;
		background-color: var(--pa-bg, #f1f5f9) !important;
		border-top: 2px solid var(--pa-border, rgba(0, 145, 234, 0.12)) !important;
		font-size: 12px !important;
		color: var(--pa-text, #263238) !important;
	}

	/* Description cell width */
	td.desc-cell {
		max-width: 280px !important;
		min-width: 180px !important;
		font-size: 12px !important;
		line-height: 1.4 !important;
	}

	/* ── Editable Input Styles ── */
	.ra-qty-input {
		width: 70px !important;
		padding: 4px 6px !important;
		border: 1px solid var(--pa-border, rgba(0, 145, 234, 0.12)) !important;
		border-radius: var(--pa-radius-sm, 8px) !important;
		background: var(--pa-surface, #fff) !important;
		font-size: 12px !important;
		font-weight: 700 !important;
		text-align: center !important;
		color: var(--pa-text, #263238) !important;
		transition: border-color var(--pa-transition, 0.25s), box-shadow var(--pa-transition, 0.25s), background-color var(--pa-transition, 0.25s) !important;
		-moz-appearance: textfield !important;
	}
	.ra-qty-input::-webkit-outer-spin-button,
	.ra-qty-input::-webkit-inner-spin-button {
		-webkit-appearance: none !important;
		margin: 0 !important;
	}
	.ra-qty-input:focus {
		outline: none !important;
		border-color: var(--pa-primary-dark, #0277BD) !important;
		box-shadow: 0 0 0 3px rgba(2, 119, 189, 0.25) !important;
		background: var(--pa-surface, #fff) !important;
	}
	.ra-qty-input.dirty {
		border-color: #f59e0b !important;
		background: #fffde7 !important;
	}
	.ra-qty-input.saved {
		border-color: #10b981 !important;
		background: #ecfdf5 !important;
	}

	/* Status toast */
	.ra-toast {
		position: fixed;
		top: 100px;
		right: 20px;
		z-index: 9999;
		padding: 12px 24px;
		border-radius: var(--pa-radius-md, 12px);
		font-size: 13px;
		font-weight: 600;
		box-shadow: var(--pa-shadow-lg);
		transition: opacity var(--pa-transition, 0.25s), transform var(--pa-transition, 0.25s);
		opacity: 0;
		transform: translateY(-10px);
		font-family: 'Inter', system-ui, sans-serif;
	}
	.ra-toast.show {
		opacity: 1;
		transform: translateY(0);
	}
	.ra-toast.success {
		background: #dcfce7;
		color: #15803d;
		border: 1px solid rgba(21, 128, 61, 0.2);
	}
	.ra-toast.error {
		background: #fee2e2;
		color: #dc2626;
		border: 1px solid rgba(220, 38, 38, 0.2);
	}

	/* Modal Styles */
	.ra-modal-backdrop {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: rgba(15, 23, 42, 0.4);
		backdrop-filter: blur(8px);
		z-index: 10000;
		display: flex;
		align-items: center;
		justify-content: center;
		opacity: 0;
		visibility: hidden;
		transition: opacity 0.3s ease, visibility 0.3s ease;
	}
	.ra-modal-backdrop.show {
		opacity: 1;
		visibility: visible;
	}
	.ra-modal {
		background: #ffffff;
		border-radius: var(--pa-radius-lg, 16px);
		box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.15), 0 10px 10px -5px rgba(0, 0, 0, 0.05);
		width: 100%;
		max-width: 550px;
		padding: 28px;
		transform: scale(0.95);
		transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
		border: 1px solid rgba(0, 145, 234, 0.1);
	}
	.ra-modal-backdrop.show .ra-modal {
		transform: scale(1);
	}
	.ra-modal-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 24px;
		border-bottom: 1.5px solid rgba(0, 145, 234, 0.1);
		padding-bottom: 14px;
	}
	.ra-modal-title {
		font-size: 20px;
		font-weight: 800;
		color: #0277bd;
		letter-spacing: -0.5px;
		font-family: 'Manrope', system-ui, sans-serif;
	}
	.ra-modal-close {
		background: none;
		border: none;
		cursor: pointer;
		color: #64748b;
		padding: 4px;
		display: flex;
		align-items: center;
		justify-content: center;
		border-radius: 50%;
		transition: background-color 0.2s;
	}
	.ra-modal-close:hover {
		background: #f1f5f9;
		color: #0f172a;
	}
	.ra-form-grid {
		display: grid !important;
		grid-template-columns: repeat(12, 1fr) !important;
		gap: 20px 24px !important;
	}
	.ra-col-span-4 {
		grid-column: span 4 !important;
	}
	.ra-col-span-8 {
		grid-column: span 8 !important;
	}
	.ra-col-span-6 {
		grid-column: span 6 !important;
	}
	.ra-form-group {
		display: flex !important;
		flex-direction: column !important;
		min-width: 0 !important;
	}
	.ra-form-label {
		display: block;
		font-size: 13px;
		font-weight: 600;
		color: #475569;
		margin-bottom: 6px;
	}
	.ra-form-input, .ra-form-select {
		width: 100% !important;
		box-sizing: border-box !important;
		border: 1.5px solid #cbd5e1 !important;
		border-radius: 8px !important;
		padding: 10px 14px !important;
		font-size: 13.5px !important;
		font-weight: 600 !important;
		font-family: inherit;
		background: #ffffff;
		color: #0f172a;
		transition: border-color 0.2s, box-shadow 0.2s;
		box-shadow: 0 1px 2px 0 rgba(15, 23, 42, 0.05) !important;
	}
	.ra-form-select {
		appearance: none;
		-webkit-appearance: none;
		-moz-appearance: none;
		background-image: url("data:image/svg+xml;charset=utf-8,%3Csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 20 20'%3E%3Cpath stroke='%23475569' stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='m6 8 4 4 4-4'/%3E%3C/svg%3E");
		background-position: right 12px center;
		background-repeat: no-repeat;
		background-size: 18px;
		padding-right: 36px !important;
		cursor: pointer;
	}
	.ra-form-input::placeholder {
		color: #94a3b8;
		font-weight: 450;
	}
	.ra-form-input:focus, .ra-form-select:focus {
		outline: none;
		border-color: #0277bd !important;
		box-shadow: 0 0 0 4px rgba(2, 119, 189, 0.15) !important;
	}
	.ra-modal-footer {
		display: flex;
		justify-content: flex-end;
		gap: 12px;
		border-top: 1.5px solid rgba(0, 145, 234, 0.1);
		padding-top: 20px;
		margin-top: 28px;
	}
	.ra-btn-cancel {
		background: #f8fafc;
		color: #475569 !important;
		border: 1.5px solid #cbd5e1;
		transition: all 0.2s ease;
	}
	.ra-btn-cancel:hover {
		background: #f1f5f9;
		border-color: #94a3b8;
	}
	.ra-btn-submit {
		background: #0277bd;
		color: #ffffff !important;
		transition: all 0.2s ease;
	}
	.ra-btn-submit:hover {
		background: #01579b;
		box-shadow: 0 4px 12px rgba(2, 119, 189, 0.25);
	}
	/* Add item button style */
	.ra-add-item-row {
		display: flex;
		justify-content: flex-start;
		padding: 16px;
		background: #fff;
		border-top: 1px dashed #cbd5e1;
	}
	.ra-btn-add-item {
		background: #0277bd;
		color: #ffffff !important;
		box-shadow: 0 2px 4px rgba(2, 119, 189, 0.15);
	}
	.ra-btn-add-item:hover {
		background: #01579b;
		box-shadow: 0 4px 8px rgba(2, 119, 189, 0.25);
	}
</style>

<div
	class="ra-excel-container" id="ra-excel-container" data-update-url="{{ update_url }}" data-nid="{{ ra_bill_nid }}">

	{# ── ACTION BUTTONS ── #}
	<div class="ra-header-actions">
		<button type="button" class="ra-btn ra-btn-save" id="ra-save-btn" disabled onclick="raSaveChanges()">
			<svg width="16" height="16" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
				<path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path>
				<polyline points="17 21 17 13 7 13 7 21"></polyline>
				<polyline points="7 3 7 8 15 8"></polyline>
			</svg>
			Save Changes
		</button>
		{% if create_invoice_url %}
			<a href="{{ create_invoice_url }}" class="ra-btn ra-btn-invoice" onclick="return confirm('Are you sure you want to create a draft invoice from this RA Bill? This will generate invoice line items from all current bill items.');">
				<svg width="16" height="16" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
					<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
					<polyline points="14 2 14 8 20 8"></polyline>
					<line x1="16" y1="13" x2="8" y2="13"></line>
					<line x1="16" y1="17" x2="8" y2="17"></line>
				</svg>
				Create Invoice
			</a>
		{% endif %}
		<a href="{{ export_url }}" class="ra-btn ra-btn-export">
			<svg width="16" height="16" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
				<path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
				<polyline points="7 10 12 15 17 10"></polyline>
				<line x1="12" y1="15" x2="12" y2="3"></line>
			</svg>
			Export to Excel
		</a>
		{% if next_bill_url %}
			<a href="{{ next_bill_url }}" class="ra-btn ra-btn-next" onclick="return confirm('Are you sure you want to create the Next RA Bill based on this bill\'s quantities? This will carry forward up-to-date quantities as previous quantities.');">
				<svg width="16" height="16" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
					<polyline points="9 18 15 12 9 6"></polyline>
				</svg>
				Next RA Bill
			</a>
		{% endif %}
	</div>

	{# ── ABSTRACT SHEET ── #}
	<div
		class="ra-abstract-sheet">

		{# Vendor Name Banner #}
		<div class="ra-vendor-banner">{{ metadata.vendor_name }}</div>

		{# Info Row 1: CLIENT | PO NO | PO DATE | INVOICE NO #}
		<div class="ra-info-row">
			<div class="ra-info-cell ra-info-cell--grow">
				<span class="ra-info-label">CLIENT:</span>
				<span class="ra-info-value">{{ metadata.client_name }}</span>
			</div>
			<div class="ra-info-cell">
				<span class="ra-info-label">PO.NO.</span>
				<span class="ra-info-value">{{ metadata.po_number }}</span>
			</div>
			<div class="ra-info-cell">
				<span class="ra-info-label">P.O DATE:</span>
				<span class="ra-info-value">{{ metadata.po_date }}</span>
			</div>
			<div class="ra-info-cell">
				<span class="ra-info-label">INVOICE NO:</span>
				<span class="ra-info-value">{{ metadata.invoice_no }}</span>
			</div>
		</div>

		{# Info Row 2: PROJECT | R.A. No | INVOICE DATE #}
		<div class="ra-info-row">
			<div class="ra-info-cell ra-info-cell--grow">
				<span class="ra-info-label">Project :</span>
				<span class="ra-info-value">
					{% if metadata.po_id %}
						<a href="/node/{{ metadata.po_id }}" style="color: var(--pa-primary-dark, #0277BD); text-decoration: underline;">{{ metadata.project }}</a>
					{% else %}
						{{ metadata.project }}
					{% endif %}
				</span>
			</div>
			<div class="ra-info-cell">
				<span class="ra-info-label">R.A. No.</span>
				<span class="ra-info-value">{{ '%02d'|format(metadata.ra_bill_number) }}</span>
			</div>
			<div class="ra-info-cell">
				<span class="ra-info-label">INVOICE Date :</span>
				<span class="ra-info-value">{{ metadata.bill_date }}</span>
			</div>
		</div>

		{# ABSTRACT Label #}
		<div class="ra-abstract-label">ABSTRAC</div>

		{# ── DATA TABLE ── #}
		<div class="ra-sheet-wrapper">
			<table class="ra-sheet-table" id="ra-abstract-table">
				<thead>
					{# Header Row 1 - Group headers #}
					<tr>
						<th rowspan="2">SL.NO.</th>
						<th rowspan="2" style="min-width: 180px;">DESCRIPTION</th>
						<th rowspan="2">UOM</th>
						<th rowspan="2">QTY</th>
						<th rowspan="2">RATE</th>
						<th rowspan="2">AMOUNT</th>
						<th colspan="4" class="group-header">QUANTITY</th>
						<th colspan="4" class="group-header">AMOUNT</th>
					</tr>
					{# Header Row 2 - Sub-headers #}
					<tr>
						<th>UPTO PREV</th>
						<th class="highlight-header">IN THIS BILL</th>
						<th>UPTO DATE</th>
						<th>BALANCE</th>
						<th>UPTO PREV</th>
						<th class="highlight-header">THIS BILL</th>
						<th>UPTO DATE</th>
						<th>BALANCE</th>
					</tr>
				</thead>
				<tbody>
					{% for item in items %}
						<tr data-paragraph-id="{{ item.paragraph_id }}" data-rate="{{ item.rate }}">
							<td class="align-center text-bold">{{ loop.index }}</td>
							<td class="align-left desc-cell">{{ item.description }}</td>
							<td class="align-center">{{ item.uom }}</td>
							<td class="align-right">{{ item.approved_qty|number_format(0, '.', ',') }}</td>
							<td class="align-right">{{ item.rate|number_format(2, '.', ',') }}</td>
							<td class="align-right">{{ item.po_amount|number_format(0, '.', ',') }}</td>
							<td class="align-right" data-col="prev_qty">{{ item.prev_qty|number_format(0, '.', ',') }}</td>
							<td class="align-center highlight-cell" data-col="current_qty">
								<input type="number" class="ra-qty-input {% if item.validation_status == 'over_claimed' %}over-claimed{% endif %}" value="{{ item.current_qty }}" data-original="{{ item.current_qty }}" data-approved="{{ item.approved_qty }}" data-paragraph-id="{{ item.paragraph_id }}" min="0" step="1" onchange="raMarkDirty(this)" onkeyup="raMarkDirty(this)" aria-label="Quantity for {{ item.description|escape('html_attr') }}"/>
								<div class="ra-qty-warning" style="{% if item.validation_status != 'over_claimed' %}display: none;{% endif %} color: #dc2626; font-size: 10px; font-weight: bold; margin-top: 4px;">Quantity exceeds approved limit.</div>
							</td>
							<td class="align-right" data-col="cumulative_qty">{{ item.cumulative_qty|number_format(0, '.', ',') }}</td>
							<td class="align-right" data-col="balance_qty">{{ item.balance_qty|number_format(0, '.', ',') }}</td>
							<td class="align-right" data-col="prev_amount">{{ item.prev_amount|number_format(2, '.', ',') }}</td>
							<td class="align-right highlight-cell" data-col="current_amount">{{ item.current_amount|number_format(2, '.', ',') }}</td>
							<td class="align-right" data-col="cumulative_amount">{{ item.cumulative_amount|number_format(2, '.', ',') }}</td>
							<td class="align-right" data-col="balance_amount">{{ item.balance_amount|number_format(2, '.', ',') }}</td>
						</tr>
					{% else %}
						<tr>
							<td colspan="14" class="align-center" style="padding: 20px; color: #64748b;">No line items found.</td>
						</tr>
					{% endfor %}
				</tbody>
				{% if items %}
					<tfoot>
						<tr class="ra-totals-row">
							<td colspan="5" class="align-right text-bold">Total</td>
							<td class="align-right text-bold" data-total="po_amount">{{ metadata.total_po_amount|number_format(2, '.', ',') }}</td>
							<td class="align-right"></td>
							<td class="align-center highlight-cell"></td>
							<td class="align-right"></td>
							<td class="align-right"></td>
							<td class="align-right text-bold" data-total="prev_amount">{{ metadata.total_prev_amount|number_format(2, '.', ',') }}</td>
							<td class="align-right highlight-cell text-bold" data-total="this_bill_amount">{{ metadata.total_this_bill_amount|number_format(2, '.', ',') }}</td>
							<td class="align-right text-bold" data-total="upto_date_amount">{{ metadata.total_upto_date_amount|number_format(2, '.', ',') }}</td>
							<td class="align-right text-bold" data-total="balance_amount">{{ metadata.total_balance_amount|number_format(2, '.', ',') }}</td>
						</tr>
					</tfoot>
				{% endif %}
			</table>
		</div>
		
		{# Add Item Button Row #}
		<div class="ra-add-item-row">
			<button type="button" class="ra-btn ra-btn-add-item" onclick="raOpenAddItemModal()">
				<svg width="16" height="16" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
					<line x1="12" y1="5" x2="12" y2="19"></line>
					<line x1="5" y1="12" x2="19" y2="12"></line>
				</svg>
				Add New Item
			</button>
		</div>
	</div>

	{# ── Add Item Modal ── #}
	<div class="ra-modal-backdrop" id="ra-add-item-modal" onclick="if(event.target===this) raCloseAddItemModal()">
		<div class="ra-modal">
			<div class="ra-modal-header">
				<h3 class="ra-modal-title">Add New Item to RA Bill</h3>
				<button type="button" class="ra-modal-close" onclick="raCloseAddItemModal()" aria-label="Close modal">
					<svg width="18" height="18" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<line x1="18" y1="6" x2="6" y2="18"></line>
						<line x1="6" y1="6" x2="18" y2="18"></line>
					</svg>
				</button>
			</div>

			<form id="ra-add-item-form" onsubmit="raSubmitAddItem(event)">
				<div class="ra-form-grid">
					<!-- Item Code and Description -->
					<div class="ra-form-group ra-col-span-4">
						<label class="ra-form-label" for="ra-input-code">Item Code / Sl.No</label>
						<input type="text" class="ra-form-input" id="ra-input-code" placeholder="e.g. 6"/>
					</div>
					<div class="ra-form-group ra-col-span-8">
						<label class="ra-form-label" for="ra-input-desc">Description <span style="color: #dc2626;">*</span></label>
						<input type="text" class="ra-form-input" id="ra-input-desc" placeholder="e.g. Media filter feed pumps" required/>
					</div>

					<!-- UOM Dropdown and Unit Rate -->
					<div class="ra-form-group ra-col-span-6">
						<label class="ra-form-label" for="ra-input-uom">Unit of Measurement (UOM)</label>
						<select class="ra-form-select" id="ra-input-uom">
							<option value="Nos">Nos</option>
							<option value="Set">Set</option>
							<option value="MT">MT</option>
							<option value="Kg">Kg</option>
							<option value="Mtr">Mtr</option>
							<option value="Sq.Mtr">Sq.Mtr</option>
							<option value="Cu.Mtr">Cu.Mtr</option>
							<option value="L.S">L.S</option>
						</select>
					</div>
					<div class="ra-form-group ra-col-span-6">
						<label class="ra-form-label" for="ra-input-rate">Unit Rate (₹) <span style="color: #dc2626;">*</span></label>
						<input type="number" step="0.01" class="ra-form-input" id="ra-input-rate" placeholder="0.00" required/>
					</div>

					<!-- PO Approved Quantity and Quantity in This Bill -->
					<div class="ra-form-group ra-col-span-6">
						<label class="ra-form-label" for="ra-input-approved">PO Approved Qty <span style="color: #dc2626;">*</span></label>
						<input type="number" step="any" class="ra-form-input" id="ra-input-approved" placeholder="0" required/>
					</div>
					<div class="ra-form-group ra-col-span-6">
						<label class="ra-form-label" for="ra-input-qty" style="color: #0f172a; font-weight: 700;">Qty in This Bill</label>
						<input type="number" step="any" class="ra-form-input" id="ra-input-qty" value="0" min="0" required/>
					</div>
				</div>

				<div class="ra-modal-footer">
					<button type="button" class="ra-btn ra-btn-cancel" onclick="raCloseAddItemModal()">Cancel</button>
					<button type="submit" class="ra-btn ra-btn-submit" id="ra-modal-submit-btn">Add to Bill</button>
				</div>
			</form>
		</div>
	</div>

	{# ── Toast notification ── #}
	<div class="ra-toast" id="ra-toast" role="alert" aria-live="polite"></div>
</div>

<script>
	(function () {
'use strict';

var dirtyFields = {};

/**
   * Mark a field as dirty when its value changes from original.
   */
window.raMarkDirty = function (input) {
var pid = input.getAttribute('data-paragraph-id');
var original = parseFloat(input.getAttribute('data-original')) || 0;
var current = parseFloat(input.value) || 0;
var approved = parseFloat(input.getAttribute('data-approved')) || 0;
var row = input.closest('tr');
var rate = parseFloat(row.getAttribute('data-rate')) || 0;

if (current !== original) {
input.classList.add('dirty');
input.classList.remove('saved');
dirtyFields[pid] = current;
} else {
input.classList.remove('dirty');
delete dirtyFields[pid];
}

// Live preview: update cumulative_qty, balance_qty, current_amount, cumulative_amount, balance_amount in-row
var prevQty = parseFloat((row.querySelector('[data-col="prev_qty"]').textContent || '0').replace(/,/g, ''));
var cumQty = prevQty + current;
var balQty = approved - cumQty;
var curAmt = current * rate;
var cumAmt = cumQty * rate;
var balAmt = balQty * rate;

row.querySelector('[data-col="cumulative_qty"]').textContent = formatNumber(cumQty, 0);
row.querySelector('[data-col="balance_qty"]').textContent = formatNumber(balQty, 0);
row.querySelector('[data-col="current_amount"]').textContent = formatNumber(curAmt, 2);
row.querySelector('[data-col="cumulative_amount"]').textContent = formatNumber(cumAmt, 2);
row.querySelector('[data-col="balance_amount"]').textContent = formatNumber(balAmt, 2);

// Real-time validation visual cue & warning message
var warningDiv = row.querySelector('.ra-qty-warning');
if (cumQty > approved) {
input.classList.add('over-claimed');
if (warningDiv) {
warningDiv.style.display = 'block';
}
// Show toast notification
showToast('Warning: Quantity exceeds approved BOQ limit.', 'error');
} else {
input.classList.remove('over-claimed');
if (warningDiv) {
warningDiv.style.display = 'none';
}
}

// Recalculate footer totals
recalcTotals();

// Toggle save button
var saveBtn = document.getElementById('ra-save-btn');
if (Object.keys(dirtyFields).length > 0) {
saveBtn.disabled = false;
} else {
saveBtn.disabled = true;
}
};

/**
   * Recalculate footer totals from all rows.
   */
function recalcTotals() {
var table = document.getElementById('ra-abstract-table');
if (! table) 
return;

var rows = table.querySelectorAll('tbody tr[data-paragraph-id]');
var totalPrev = 0,
totalThis = 0,
totalUpto = 0,
totalBalance = 0;

rows.forEach(function (row) {
totalPrev += parseCellNum(row.querySelector('[data-col="prev_amount"]'));
totalThis += parseCellNum(row.querySelector('[data-col="current_amount"]'));
totalUpto += parseCellNum(row.querySelector('[data-col="cumulative_amount"]'));
totalBalance += parseCellNum(row.querySelector('[data-col="balance_amount"]'));
});

setTotalCell('prev_amount', totalPrev);
setTotalCell('this_bill_amount', totalThis);
setTotalCell('upto_date_amount', totalUpto);
setTotalCell('balance_amount', totalBalance);
}

function parseCellNum(cell) {
if (! cell) 
return 0;



return parseFloat(cell.textContent.replace(/,/g, '')) || 0;
}

function setTotalCell(name, val) {
var cell = document.querySelector('[data-total="' + name + '"]');
if (cell) 
cell.textContent = formatNumber(val, 2);



}

function formatNumber(num, decimals) {
return num.toLocaleString('en-IN', {
minimumFractionDigits: decimals,
maximumFractionDigits: decimals
});
}

/**
   * Save all dirty fields via AJAX.
   */
window.raSaveChanges = function () {
var keys = Object.keys(dirtyFields);
if (keys.length === 0) 
return;



var container = document.getElementById('ra-excel-container');
var updateUrl = container.getAttribute('data-update-url');
var saveBtn = document.getElementById('ra-save-btn');

saveBtn.disabled = true;
saveBtn.classList.add('saving');
saveBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:6px;animation:spin 1s linear infinite"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg> Saving...';

var updates = keys.map(function (pid) {
return {paragraph_id: parseInt(pid), current_qty: dirtyFields[pid]};
});

fetch(updateUrl, {
method: 'POST',
headers: {
'Content-Type': 'application/json',
'X-Requested-With': 'XMLHttpRequest'
},
body: JSON.stringify(
{updates: updates}
)
}).then(function (response) {
return response.json();
}).then(function (data) {
if (data.success) { // Update each row with server-confirmed data
(data.rows || []).forEach(function (row) {
var tr = document.querySelector('tr[data-paragraph-id="' + row.paragraph_id + '"]');
if (! tr) 
return;

var approved = parseFloat(tr.querySelector('.ra-qty-input').getAttribute('data-approved')) || 0;
var balQty = approved - row.cumulative_qty;
var rate = parseFloat(tr.getAttribute('data-rate')) || 0;
var balAmt = balQty * rate;

tr.querySelector('[data-col="prev_qty"]').textContent = formatNumber(row.prev_qty, 0);
tr.querySelector('[data-col="cumulative_qty"]').textContent = formatNumber(row.cumulative_qty, 0);
tr.querySelector('[data-col="balance_qty"]').textContent = formatNumber(balQty, 0);
tr.querySelector('[data-col="prev_amount"]').textContent = formatNumber(row.prev_amount, 2);
tr.querySelector('[data-col="current_amount"]').textContent = formatNumber(row.current_amount, 2);
tr.querySelector('[data-col="cumulative_amount"]').textContent = formatNumber(row.cumulative_amount, 2);
tr.querySelector('[data-col="balance_amount"]').textContent = formatNumber(balAmt, 2);

// Update validation class & warning style
var warningDiv = tr.querySelector('.ra-qty-warning');
var input = tr.querySelector('.ra-qty-input');
if (row.validation_status === 'over_claimed') {
if (input) input.classList.add('over-claimed');
if (warningDiv) warningDiv.style.display = 'block';
} else {
if (input) input.classList.remove('over-claimed');
if (warningDiv) warningDiv.style.display = 'none';
}

// Update input original value and mark as saved
if (input) {
input.setAttribute('data-original', row.current_qty);
input.classList.remove('dirty');
input.classList.add('saved');
setTimeout(function () {
input.classList.remove('saved');
}, 2000);
}
});

// Update totals
if (data.totals) {
setTotalCell('prev_amount', data.totals.total_prev_amount);
setTotalCell('this_bill_amount', data.totals.total_this_bill_amount);
setTotalCell('upto_date_amount', data.totals.total_upto_date_amount);
setTotalCell('po_amount', data.totals.total_po_amount);
var totalBalance = data.totals.total_po_amount - data.totals.total_upto_date_amount;
setTotalCell('balance_amount', totalBalance);
}

dirtyFields = {};
showToast('Changes saved successfully!', 'success');
} else {
showToast('Error: ' + (
data.error || 'Unknown error'
), 'error');
}
}).catch(function (err) {
showToast('Network error: ' + err.message, 'error');
}). finally(function () {
saveBtn.classList.remove('saving');
saveBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-right: 6px;"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg> Save Changes';
saveBtn.disabled = Object.keys(dirtyFields).length === 0;
});
};

function showToast(message, type) {
var toast = document.getElementById('ra-toast');
toast.textContent = message;
toast.className = 'ra-toast ' + type + ' show';
setTimeout(function () {
toast.classList.remove('show');
}, 3000);
}

window.raOpenAddItemModal = function () {
  document.getElementById('ra-add-item-modal').classList.add('show');
};

window.raCloseAddItemModal = function () {
  document.getElementById('ra-add-item-modal').classList.remove('show');
  document.getElementById('ra-add-item-form').reset();
};

function escapeHtml(str) {
  if (!str) return '';
  return String(str)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#039;');
}

window.raSubmitAddItem = function (event) {
  event.preventDefault();
  
  var currentQty = parseFloat(document.getElementById('ra-input-qty').value) || 0;
  var code = document.getElementById('ra-input-code').value;
  var desc = document.getElementById('ra-input-desc').value;
  var uom = document.getElementById('ra-input-uom').value;
  var rate = parseFloat(document.getElementById('ra-input-rate').value) || 0;
  var approved = parseFloat(document.getElementById('ra-input-approved').value) || 0;
  
  if (!desc) {
    showToast('Please enter a description.', 'error');
    return;
  }
  
  var payload = {
    current_qty: currentQty,
    item_code: code,
    description: desc,
    uom: uom,
    rate: rate,
    approved_qty: approved
  };
  
  var container = document.getElementById('ra-excel-container');
  var nid = container.getAttribute('data-nid');
  var url = '/admin/ra-bills/' + nid + '/add-item';
  
  var submitBtn = document.getElementById('ra-modal-submit-btn');
  submitBtn.disabled = true;
  submitBtn.textContent = 'Adding...';
  
  fetch(url, {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'X-Requested-With': 'XMLHttpRequest'
    },
    body: JSON.stringify(payload)
  })
  .then(function (response) {
    return response.json();
  })
  .then(function (data) {
    if (data.success) {
      var item = data.item;
      
      // Append row to table
      var tr = document.createElement('tr');
      tr.setAttribute('data-paragraph-id', item.paragraph_id);
      tr.setAttribute('data-rate', item.rate);
      
      var index = document.querySelectorAll('#ra-abstract-table tbody tr[data-paragraph-id]').length + 1;
      
      tr.innerHTML = 
        '<td class="align-center text-bold">' + index + '</td>' +
        '<td class="align-left desc-cell">' + escapeHtml(item.description) + '</td>' +
        '<td class="align-center">' + escapeHtml(item.uom) + '</td>' +
        '<td class="align-right">' + formatNumber(item.approved_qty, 0) + '</td>' +
        '<td class="align-right">' + formatNumber(item.rate, 2) + '</td>' +
        '<td class="align-right">' + formatNumber(item.po_amount, 0) + '</td>' +
        '<td class="align-right" data-col="prev_qty">' + formatNumber(item.prev_qty, 0) + '</td>' +
        '<td class="align-center highlight-cell" data-col="current_qty">' +
          '<input type="number" class="ra-qty-input ' + (item.validation_status === 'over_claimed' ? 'over-claimed' : '') + '" value="' + item.current_qty + '" data-original="' + item.current_qty + '" data-approved="' + item.approved_qty + '" data-paragraph-id="' + item.paragraph_id + '" min="0" step="1" onchange="raMarkDirty(this)" onkeyup="raMarkDirty(this)" aria-label="Quantity for ' + escapeHtml(item.description) + '"/>' +
          '<div class="ra-qty-warning" style="' + (item.validation_status !== 'over_claimed' ? 'display: none;' : '') + ' color: #dc2626; font-size: 10px; font-weight: bold; margin-top: 4px;">Quantity exceeds approved limit.</div>' +
        '</td>' +
        '<td class="align-right" data-col="cumulative_qty">' + formatNumber(item.cumulative_qty, 0) + '</td>' +
        '<td class="align-right" data-col="balance_qty">' + formatNumber(item.balance_qty, 0) + '</td>' +
        '<td class="align-right" data-col="prev_amount">' + formatNumber(item.prev_amount, 2) + '</td>' +
        '<td class="align-right highlight-cell" data-col="current_amount">' + formatNumber(item.current_amount, 2) + '</td>' +
        '<td class="align-right" data-col="cumulative_amount">' + formatNumber(item.cumulative_amount, 2) + '</td>' +
        '<td class="align-right" data-col="balance_amount">' + formatNumber(item.balance_amount, 2) + '</td>';
      
      var tbody = document.querySelector('#ra-abstract-table tbody');
      var emptyRow = tbody.querySelector('tr td[colspan]');
      if (emptyRow && emptyRow.closest('tr')) {
        emptyRow.closest('tr').remove();
      }
      tbody.appendChild(tr);
      
      // Update totals
      if (data.totals) {
        setTotalCell('prev_amount', data.totals.total_prev_amount);
        setTotalCell('this_bill_amount', data.totals.total_this_bill_amount);
        setTotalCell('upto_date_amount', data.totals.total_upto_date_amount);
        setTotalCell('po_amount', data.totals.total_po_amount);
        var totalBalance = data.totals.total_po_amount - data.totals.total_upto_date_amount;
        setTotalCell('balance_amount', totalBalance);
      }
      
      raCloseAddItemModal();
      showToast('Item added successfully!', 'success');
    } else {
      showToast('Error: ' + (data.error || 'Unknown error'), 'error');
    }
  })
  .catch(function (err) {
    showToast('Network error: ' + err.message, 'error');
  })
  .finally(function () {
    submitBtn.disabled = false;
    submitBtn.textContent = 'Add to Bill';
  });
};
})();
</script>
